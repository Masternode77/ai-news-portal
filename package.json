{
  "name": "compute-current",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0",
    "npm": ">=9.6.5"
  },
  "scripts": {
    "dev": "astro dev",
    "pipeline": "node ./scripts/content-command-surface.mjs cycle --production",
    "test:curation": "PIPELINE_OFFLINE=1 OPENROUTER_API_KEY= node ./scripts/test-curation.mjs",
    "test:editorial": "node ./scripts/test-editorial-humanizer.mjs",
    "test:quality-gate": "node ./scripts/test-quality-gate.mjs",
    "humanize:existing": "node ./scripts/humanize-existing-articles.mjs",
    "smoke:image-provider": "IMAGE_PROVIDER=local PIPELINE_OFFLINE=1 node ./scripts/image-provider-dry-run.mjs",
    "prepare:static-images": "node ./scripts/prepare-static-images.mjs",
    "regenerate:stock-card-images": "node ./scripts/regenerate-stock-card-images.mjs",
    "backfill:article-metadata": "node ./scripts/backfill-article-metadata.mjs",
    "build": "npm run prepare:static-images && node ./scripts/export-admin-public-read-model.mjs --if-configured && astro build && node ./scripts/prune-dist-images.mjs",
    "check": "astro check",
    "preview": "astro preview",
    "astro": "astro",
    "qa:visual:capture": "node ./scripts/qa-visual-capture.mjs",
    "qa:visual:smoke": "node ./scripts/qa-visual-smoke.mjs",
    "qa:visual:status": "node ./scripts/qa-visual-status.mjs",
    "qa:visual:commercial": "node ./scripts/qa-commercial-visual.mjs",
    "qa:visual:design-lab": "node ./scripts/qa-design-lab-visual.mjs",
    "qa:visual:percy": "node ./scripts/qa-visual-percy.mjs",
    "qa:qc": "node ./scripts/run-qa-qc.mjs",
    "test:relevance": "node ./scripts/test-relevance-classifier.mjs",
    "test:taxonomy": "node ./scripts/test-taxonomy.mjs",
    "test:blueprints": "PIPELINE_OFFLINE=1 OPENROUTER_API_KEY= node ./scripts/test-blueprints.mjs",
    "test:repetition": "node ./scripts/test-repetition-detector.mjs",
    "test:expert-insight": "PIPELINE_OFFLINE=1 OPENROUTER_API_KEY= node ./scripts/test-expert-insight-engine.mjs",
    "test:public-content": "node ./scripts/test-public-content-regression.mjs",
    "test": "node --test tests/*.test.mjs && npm run test:quality-gate && npm run test:relevance && npm run test:taxonomy && npm run test:repetition",
    "test:quality-gates": "node --test tests/article-detail-quality-gate.test.mjs tests/boilerplate-detector.test.mjs tests/homepage-quality-filter.test.mjs tests/public-template-phrase-guard.test.mjs tests/seo-quality-policy.test.mjs tests/source-extraction-fail-closed.test.mjs tests/source-text-completeness.test.mjs tests/strict-infrastructure-relevance-router.test.mjs tests/truncation-detector.test.mjs tests/proper-noun-normalizer.test.mjs",
    "test:source-expansion": "node --test tests/source-registry.test.mjs tests/source-feed-discovery.test.mjs",
    "test:blog-engine-v4": "node --test tests/graded-publishing-router.test.mjs tests/blog-eligibility-policy.test.mjs tests/blog-engine-v4.test.mjs tests/blog-length-policy.test.mjs tests/blog-tone-selector.test.mjs tests/blog-archetype-selector.test.mjs tests/human-blog-quality-score.test.mjs tests/multi-source-corroboration.test.mjs tests/source-fidelity-claim-check.test.mjs tests/homepage-blog-surface-policy.test.mjs tests/homepage-backfill.test.mjs tests/article-page-template.test.mjs tests/blog-surface-v4-regression.test.mjs",
    "cleanup:public-content": "node ./scripts/emergency-cleanup-public-content.mjs",
    "regenerate:clean-content": "node ./scripts/regenerate-clean-content.mjs",
    "regenerate:blog-surface-v4": "node ./scripts/regenerate-blog-surface-v4.mjs",
    "backfill:homepage-blogs": "node ./scripts/backfill-homepage-blogs.mjs",
    "regenerate:narrative-dna": "node ./scripts/regenerate-narrative-dna-articles.mjs",
    "regenerate:public-content-v2": "node ./scripts/regenerate-public-content-v2.mjs",
    "migrate:legacy": "node ./scripts/migrate-legacy-content.mjs",
    "admin:migrate": "node ./scripts/migrate-admin-storage.mjs",
    "admin:verify-managed": "node ./scripts/verify-managed-admin-persistence.mjs",
    "admin:export-public": "node ./scripts/export-admin-public-read-model.mjs",
    "regen:latest100": "node ./scripts/regenerate-latest100.mjs",
    "generate:missing-images": "node ./scripts/generate-missing-images.mjs",
    "purge:deployment-cache": "node ./scripts/purge-deployment-cache.mjs",
    "purge:public-cache": "node ./scripts/purge-public-cache.mjs",
    "purge:cache": "node ./scripts/purge-public-cache.mjs",
    "audit:content-quality": "npm run build && node ./scripts/audit-public-content-quality.mjs",
    "audit:public-surface": "npm run build && node ./scripts/audit-public-surface.mjs",
    "audit:blog-surface-v4": "npm run build && node ./scripts/audit-blog-surface-v4.mjs",
    "audit:public-copy": "node scripts/audit-public-copy.mjs",
    "audit:public-images": "node scripts/audit-public-images.mjs",
    "audit:images": "node scripts/audit-public-images.mjs",
    "audit:homepage": "node scripts/audit-public-homepage.mjs",
    "audit:article-quality": "node scripts/audit-public-article-quality.mjs",
    "audit:feed-volume": "node scripts/audit-public-feed-volume.mjs",
    "audit:public": "node ./scripts/audit-rendered-public-output.mjs && node ./scripts/audit-public-copy.mjs && node ./scripts/audit-public-article-quality.mjs && npm run audit:homepage && npm run audit:feed-volume",
    "audit:production": "node ./scripts/verify-production-surface.mjs --skip-cache-purge",
    "audit:admin": "node ./scripts/audit-admin-exclusion.mjs",
    "content:gate": "npm run check && npm run build && node --test tests/public-output.test.mjs tests/image-output.test.mjs tests/admin-security.test.mjs tests/content-cycle.test.mjs && npm run audit:public && npm run audit:images && npm run audit:admin",
    "audit:autonomous-current": "node ./scripts/audit-autonomous-current-state.mjs",
    "run:editorial-cycle": "node ./scripts/run-editorial-cycle.mjs",
    "content:ingest": "node ./scripts/content-command-surface.mjs ingest",
    "content:extract": "node ./scripts/content-command-surface.mjs extract",
    "content:classify": "node ./scripts/content-command-surface.mjs classify",
    "content:cluster": "node ./scripts/content-command-surface.mjs cluster",
    "content:generate": "node ./scripts/content-command-surface.mjs generate",
    "content:review": "node ./scripts/content-command-surface.mjs review",
    "content:publish": "node ./scripts/content-command-surface.mjs publish",
    "content:cycle": "node ./scripts/content-command-surface.mjs cycle --production",
    "content:eval": "node ./scripts/content-command-surface.mjs eval",
    "test:signal-clusters": "node --test tests/signal-clusterer.test.mjs tests/signal-scoring-engine.test.mjs tests/editorial-selection-engine.test.mjs",
    "test:claim-ledger": "node --test tests/claim-ledger.test.mjs tests/numeric-claim-verifier.test.mjs tests/unsupported-claim-guard.test.mjs",
    "test:autonomous-desk": "node --test tests/editorial-cycle.test.mjs tests/global-source-scan.test.mjs tests/evidence-pack-builder-v2.test.mjs tests/editorial-thesis-generator.test.mjs tests/autonomous-blog-writer-v1.test.mjs tests/voice-variation-engine.test.mjs tests/editorial-archetype-router-v2.test.mjs tests/anti-template-guard-v2.test.mjs tests/human-style-score.test.mjs tests/insight-density-score.test.mjs tests/freshness-monitor.test.mjs tests/homepage-editorial-model.test.mjs tests/taxonomy-page-builder.test.mjs tests/company-entity-index.test.mjs tests/region-index.test.mjs tests/rss-builder.test.mjs tests/sitemap-builder.test.mjs tests/article-page-autonomous.test.mjs tests/copyright-safe-copy-guard.test.mjs tests/autonomous-public-surface.test.mjs",
    "migrate:autonomous-desk-v1": "node ./scripts/migrate-autonomous-editorial-desk-v1.mjs",
    "repair:public-longforms": "node ./scripts/repair-public-longform-inventory.mjs",
    "repair:public-longforms:apply": "node ./scripts/repair-public-longform-inventory.mjs --apply",
    "regenerate:autonomous-analyses-v1": "node ./scripts/regenerate-autonomous-analyses-v1.mjs",
    "rebuild:taxonomy-pages": "node ./scripts/rebuild-taxonomy-pages.mjs",
    "audit:autonomous-public": "npm run build && node ./scripts/audit-autonomous-public-surface.mjs",
    "eval:articles": "npm run content:eval",
    "benchmark:prepare": "node ./scripts/prepare-human-content-benchmark.mjs",
    "benchmark:score": "node ./scripts/score-human-content-benchmark.mjs"
  },
  "dependencies": {
    "@astrojs/rss": "^4.0.12",
    "@astrojs/sitemap": "^3.6.0",
    "@node-rs/argon2": "^2.0.2",
    "@vercel/blob": "^2.6.1",
    "astro": "^7.0.7",
    "postgres": "^3.4.9",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.6",
    "rss-parser": "^3.13.0",
    "typescript": "^5.9.3"
  }
}
