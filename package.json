{
  "name": "compute-current",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "sync:dashboard-data": "node ./scripts/sync-dashboard-data.cjs",
    "dev": "astro dev",
    "pipeline": "node ./scripts/pipeline.mjs",
    "test:curation": "PIPELINE_OFFLINE=1 OPENROUTER_API_KEY= node ./scripts/test-curation.mjs",
    "test:editorial": "node ./scripts/test-editorial-humanizer.mjs",
    "test:quality-gate": "node ./scripts/test-quality-gate.mjs",
    "humanize:existing": "node ./scripts/humanize-existing-articles.mjs",
    "smoke:image-provider": "IMAGE_PROVIDER=local PIPELINE_OFFLINE=1 node ./scripts/image-provider-dry-run.mjs",
    "prepare:static-images": "node ./scripts/prepare-static-images.mjs",
    "backfill:article-metadata": "node ./scripts/backfill-article-metadata.mjs",
    "build": "npm run sync:dashboard-data && npm run prepare:static-images && astro build",
    "check": "astro check",
    "preview": "astro preview",
    "astro": "astro",
    "qa:visual:capture": "node ./scripts/qa-visual-capture.mjs",
    "qa:visual:smoke": "node ./scripts/qa-visual-smoke.mjs",
    "qa:visual:status": "node ./scripts/qa-visual-status.mjs",
    "qa:visual:percy": "node ./scripts/qa-visual-percy.mjs",
    "test:relevance": "node ./scripts/test-relevance-classifier.mjs",
    "test:taxonomy": "node ./scripts/test-taxonomy.mjs",
    "test:blueprints": "PIPELINE_OFFLINE=1 OPENROUTER_API_KEY= node ./scripts/test-blueprints.mjs",
    "test:repetition": "node ./scripts/test-repetition-detector.mjs",
    "test:expert-insight": "PIPELINE_OFFLINE=1 OPENROUTER_API_KEY= node ./scripts/test-expert-insight-engine.mjs",
    "test:public-content": "node ./scripts/test-public-content-regression.mjs",
    "test": "node --test tests/*.test.mjs && npm run test:quality-gate && npm run test:relevance && npm run test:taxonomy && npm run test:repetition",
    "test:quality-gates": "node --test tests/article-detail-quality-gate.test.mjs tests/boilerplate-detector.test.mjs tests/homepage-quality-filter.test.mjs tests/public-template-phrase-guard.test.mjs tests/seo-quality-policy.test.mjs tests/source-extraction-fail-closed.test.mjs tests/source-text-completeness.test.mjs tests/strict-infrastructure-relevance-router.test.mjs tests/truncation-detector.test.mjs tests/proper-noun-normalizer.test.mjs",
    "cleanup:public-content": "node ./scripts/emergency-cleanup-public-content.mjs",
    "regenerate:clean-content": "node ./scripts/regenerate-clean-content.mjs",
    "regenerate:narrative-dna": "node ./scripts/regenerate-narrative-dna-articles.mjs",
    "regenerate:public-content-v2": "node ./scripts/regenerate-public-content-v2.mjs",
    "purge:deployment-cache": "node ./scripts/purge-deployment-cache.mjs",
    "purge:public-cache": "node ./scripts/purge-public-cache.mjs",
    "audit:content-quality": "npm run build && node ./scripts/audit-public-content-quality.mjs",
    "audit:public-surface": "npm run build && node ./scripts/audit-public-surface.mjs",
    "eval:articles": "node ./scripts/eval-article-generation.mjs"
  },
  "dependencies": {
    "@astrojs/rss": "^4.0.12",
    "@astrojs/sitemap": "^3.6.0",
    "astro": "^5.17.1",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.6",
    "rss-parser": "^3.13.0",
    "typescript": "^5.9.3"
  }
}
