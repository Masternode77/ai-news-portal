{
  "framework": "astro",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/admin/*.js": {
      "includeFiles": "{config/**/*.yml,config/**/*.json,src/data/{editorial-cycles,claim-ledger,source-health}.json}"
    }
  },
  "rewrites": [
    {
      "source": "/admin/articles/:id/edit",
      "destination": "/admin/articles/editor/?id=:id"
    },
    {
      "source": "/admin/articles/:id",
      "destination": "/admin/articles/editor/?id=:id"
    }
  ],
  "redirects": [
    { "source": "/admin", "destination": "/admin/login/", "permanent": false },
    { "source": "/admin.html", "destination": "/admin/login/", "permanent": false },
    { "source": "/admin/edit/:id", "destination": "/admin/articles/:id/edit", "permanent": false },
    { "source": "/admin/source-health", "destination": "/admin/sources/", "permanent": false },
    { "source": "/admin/content-quality", "destination": "/admin/quarantine/", "permanent": false },
    { "source": "/admin/content-quality/:id", "destination": "/admin/quarantine/", "permanent": false },
    { "source": "/admin/claim-ledger", "destination": "/admin/quarantine/", "permanent": false },
    { "source": "/admin/editorial-cycles", "destination": "/admin/pipeline/", "permanent": false },
    { "source": "/admin/editorial-cycles/:id", "destination": "/admin/pipeline/", "permanent": false },
    { "source": "/admin/signal-clusters", "destination": "/admin/pipeline/", "permanent": false }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' https: data:; connect-src 'self'; object-src 'none'; base-uri 'self'; frame-ancestors 'none'; form-action 'self'; upgrade-insecure-requests"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), payment=(), usb=()"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        }
      ]
    },
    {
      "source": "/api/admin/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        },
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        }
      ]
    },
    {
      "source": "/admin/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, private" },
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    }
  ]
}
