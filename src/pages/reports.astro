---
import Layout from '../layouts/Layout.astro';
import ReportCard from '../components/ReportCard.astro';
import { SITE } from '../config/site';
import { allReports } from '../../scripts/lib/reports-store.mjs';
---
<Layout
  title={`Reports | ${SITE.name}`}
  description="Premium AI infrastructure research reports from Compute Current."
  canonicalPath="/reports/"
>
  <main class="product-shell">
    <section class="product-hero">
      <p class="eyebrow">Premium Reports</p>
      <h1>Research products for infrastructure decisions.</h1>
      <p>
        Report pages include a free preview and request flow until payment integration is configured.
      </p>
    </section>
    <section class="reports-grid">
      {allReports().map((report) => <ReportCard report={report} />)}
    </section>
  </main>
</Layout>
