---
import Layout from '../../layouts/Layout.astro';
import LatestAnalysisFeed from '../../components/LatestAnalysisFeed.astro';
import PublicListingPage from '../../components/PublicListingPage.astro';
import { publicContentInventory } from '../../lib/public-content-inventory.js';
import { SITE } from '../../config/site';
import { buildArchiveFeed } from '../../../scripts/lib/archive-feed-builder.mjs';

const feed = buildArchiveFeed(publicContentInventory, { page: 1, pageSize: 50 });
---
<Layout title={`Publication archive | ${SITE.name}`} description="Browse the Compute Current publication archive." canonicalPath="/archive/">
  <PublicListingPage
    eyebrow="Publication archive"
    title="AI infrastructure intelligence archive"
    lede="Browse recent analysis and source-linked briefs across power, capacity, cloud, silicon, cooling, policy and capital."
    activePath="/archive/"
  >
    <LatestAnalysisFeed feed={feed} title="Recent intelligence" eyebrow="Publication archive" dek="" />
    {feed.pageCount > 1 ? (
      <nav class="public-pagination" aria-label="Archive pages">
        <span aria-current="page">1</span>
        {Array.from({ length: feed.pageCount - 1 }, (_, index) => index + 2).map((page) => (
          <a href={`/archive/${page}/`}>{page}</a>
        ))}
      </nav>
    ) : null}
  </PublicListingPage>
</Layout>
