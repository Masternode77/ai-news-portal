---
import Layout from '../../layouts/Layout.astro';
import LatestAnalysisFeed from '../../components/LatestAnalysisFeed.astro';
import latestNews from '../../data/latest-news.json';
import archivedNews from '../../data/archived-news.json';
import { SITE } from '../../config/site';
import { buildArchiveFeed } from '../../../scripts/lib/archive-feed-builder.mjs';

const feed = buildArchiveFeed([...latestNews, ...archivedNews], { page: 1, pageSize: 50 });
---
<Layout title={`Archive | ${SITE.name}`} description="Search the Compute Current archive." canonicalPath="/archive/">
  <main class="policy-shell taxonomy-page publication-archive">
    <a class="back-link" href="/">Latest analysis</a>
    <section class="policy-page">
      <p class="eyebrow">Archive</p>
      <h1>Search the archive</h1>
      <p class="policy-lede">Browse recent AI infrastructure analysis, briefs, and signals.</p>
    </section>
    <LatestAnalysisFeed feed={feed} title="Browse Recent Analysis" dek="" />
  </main>
</Layout>
