---
import Layout from '../../layouts/Layout.astro';
import LatestAnalysisFeed from '../../components/LatestAnalysisFeed.astro';
import latestNews from '../../data/latest-news.json';
import archivedNews from '../../data/archived-news.json';
import { SITE } from '../../config/site';
import { buildArchiveFeed } from '../../../scripts/lib/archive-feed-builder.mjs';

const feed = buildArchiveFeed([...latestNews, ...archivedNews], { page: 1, pageSize: 50 });
---
<Layout title={`Publication archive | ${SITE.name}`} description="Browse the Compute Current publication archive." canonicalPath="/archive/">
  <main class="policy-shell taxonomy-page publication-archive">
    <a class="back-link" href="/">Read the latest</a>
    <section class="policy-page">
      <p class="eyebrow">Publication archive</p>
      <h1>Publication archive</h1>
      <p class="policy-lede">Browse recent AI infrastructure intelligence, briefs, and source-linked analysis.</p>
    </section>
    <LatestAnalysisFeed feed={feed} title="Recent intelligence" eyebrow="Publication archive" dek="" />
  </main>
</Layout>
