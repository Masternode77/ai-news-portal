---
import Layout from '../../layouts/Layout.astro';
import LatestAnalysisFeed from '../../components/LatestAnalysisFeed.astro';
import PublicListingPage from '../../components/PublicListingPage.astro';
import latestNews from '../../data/latest-news.json';
import archivedNews from '../../data/archived-news.json';
import { SITE } from '../../config/site';
import { buildArchiveFeed } from '../../../scripts/lib/archive-feed-builder.mjs';

export function getStaticPaths() {
  const rootFeed = buildArchiveFeed([...latestNews, ...archivedNews], { page: 1, pageSize: 50 });
  return Array.from({ length: Math.max(0, rootFeed.pageCount - 1) }, (_, index) => {
    const pageNumber = index + 2;
    return {
      params: { page: String(pageNumber) },
      props: { pageNumber },
    };
  });
}

const { pageNumber } = Astro.props;
const feed = buildArchiveFeed([...latestNews, ...archivedNews], { page: pageNumber, pageSize: 50 });
---
<Layout title={`Publication archive page ${pageNumber} | ${SITE.name}`} description="Compute Current publication archive page." canonicalPath={`/archive/${pageNumber}/`}>
  <PublicListingPage
    eyebrow="Publication archive"
    title={`AI infrastructure archive, page ${pageNumber}`}
    lede="Continue through published analysis and source-linked briefs across the physical systems behind AI deployment."
    activePath="/archive/"
  >
    <LatestAnalysisFeed feed={feed} title="Recent intelligence" eyebrow="Publication archive" dek="" />
    <nav class="public-pagination" aria-label="Archive pages">
      {Array.from({ length: feed.pageCount }, (_, index) => index + 1).map((page) => (
        page === pageNumber
          ? <span aria-current="page">{page}</span>
          : <a href={page === 1 ? '/archive/' : `/archive/${page}/`}>{page}</a>
      ))}
    </nav>
  </PublicListingPage>
</Layout>
