---
import Layout from '../../layouts/Layout.astro';
import LatestAnalysisFeed from '../../components/LatestAnalysisFeed.astro';
import latestNews from '../../data/latest-news.json';
import archivedNews from '../../data/archived-news.json';
import { SITE } from '../../config/site';
import { buildArchiveFeed } from '../../../scripts/lib/archive-feed-builder.mjs';

export function getStaticPaths() {
  const rootFeed = buildArchiveFeed([...latestNews, ...archivedNews], { page: 1, pageSize: 50 });
  return Array.from({ length: Math.max(0, rootFeed.pageCount - 1) }, (_, index) => {
    const pageNumber = index + 2;
    return {
      params: { page: String(pageNumber) },
      props: { pageNumber },
    };
  });
}

const { pageNumber } = Astro.props;
const feed = buildArchiveFeed([...latestNews, ...archivedNews], { page: pageNumber, pageSize: 50 });
---
<Layout title={`Archive page ${pageNumber} | ${SITE.name}`} description="Compute Current archive page." canonicalPath={`/archive/${pageNumber}/`}>
  <main class="policy-shell taxonomy-page publication-archive">
    <a class="back-link" href="/archive/">Archive</a>
    <section class="policy-page">
      <p class="eyebrow">Archive</p>
      <h1>Archive page {pageNumber}</h1>
      <p class="policy-lede">Browse recent AI infrastructure analysis, briefs, and signals.</p>
    </section>
    <LatestAnalysisFeed feed={feed} title="Browse Recent Analysis" dek="" />
  </main>
</Layout>
