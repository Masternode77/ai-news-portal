---
import Layout from '../layouts/Layout.astro';
import { SITE } from '../config/site';
import { SPONSOR_PRODUCTS } from '../../scripts/lib/sponsor-inventory.mjs';

const audienceRoles = [
  'Data center operators',
  'Colocation and wholesale teams',
  'Hyperscaler/cloud capacity teams',
  'AI infrastructure investors',
  'Power and grid stakeholders',
  'Semiconductor and networking suppliers',
  'Enterprise infrastructure buyers',
  'Policy and siting professionals',
];
const coverage = ['Power & Grid', 'Data Centers', 'Cooling & Thermal', 'Silicon & Systems', 'Cloud Capacity', 'Capital & Deals', 'Policy & Siting', 'Enterprise Infrastructure'];
const advertisers = ['Liquid cooling', 'Power equipment', 'UPS and electrical systems', 'Data center developers', 'Colocation providers', 'Neoclouds/GPU cloud', 'Networking and fiber', 'Storage and backup', 'Software infrastructure', 'Project finance', 'Legal/permitting', 'Industry events'];
---
<Layout
  title={`Media Kit | ${SITE.name}`}
  description="Media kit for Compute Current, an AI infrastructure intelligence publication."
  canonicalPath="/media-kit/"
>
  <main class="product-shell" data-page-event="media_kit_view">
    <section class="product-hero">
      <p class="eyebrow">Media Kit</p>
      <h1>Compute Current tracks the constraints behind the AI buildout.</h1>
      <p>
        Compute Current is an AI infrastructure intelligence publication tracking power, cooling, semiconductors, cloud capacity, data centers, capital flows, and policy risk.
      </p>
    </section>

    <section class="media-metrics">
      {['Monthly pageviews', 'Email subscribers', 'Audience geography'].map((metric) => (
        <article>
          <span>{metric}</span>
          <strong>Available on request</strong>
        </article>
      ))}
    </section>

    <section class="product-grid product-grid-three">
      <article class="product-card"><h2>Audience roles</h2><ul>{audienceRoles.map((item) => <li>{item}</li>)}</ul></article>
      <article class="product-card"><h2>Coverage lanes</h2><ul>{coverage.map((item) => <li>{item}</li>)}</ul></article>
      <article class="product-card"><h2>Advertiser categories</h2><ul>{advertisers.map((item) => <li>{item}</li>)}</ul></article>
    </section>

    <section class="product-band">
      <div>
        <p class="eyebrow">Sponsorship Packages</p>
        <h2>{SPONSOR_PRODUCTS.join(', ')}</h2>
      </div>
      <a class="product-button" href="/advertise/" data-analytics-event="advertise_cta_click" data-analytics-label="Media kit sponsor CTA">Request media kit details</a>
    </section>

    <section class="lead-form-panel">
      <div>
        <p class="eyebrow">Media Kit Contact</p>
        <h2>Request audience details or package availability.</h2>
      </div>
      <form class="conversion-form" data-form-name="media-kit-contact" data-analytics-submit="sponsor_inquiry_submit">
        <div class="form-grid-two">
          <label><span>Name</span><input name="name" required /></label>
          <label><span>Company</span><input name="company" required /></label>
        </div>
        <label><span>Email</span><input name="email" type="email" required /></label>
        <label><span>Message</span><textarea name="message" rows="4"></textarea></label>
        <button type="submit">Request media kit</button>
        <p class="form-status" data-form-status></p>
      </form>
    </section>
  </main>
</Layout>
