---
import Layout from '../../layouts/Layout.astro';
import PublicArticleHeader from '../../components/PublicArticleHeader.astro';
import PublicArticleBody from '../../components/PublicArticleBody.astro';
import PublicAtAGlance from '../../components/PublicAtAGlance.astro';
import PublicWhatToWatch from '../../components/PublicWhatToWatch.astro';
import PublicBottomLine from '../../components/PublicBottomLine.astro';
import NewsletterCapture from '../../components/NewsletterCapture.astro';
import latestNews from '../../data/latest-news.json';
import archivedNews from '../../data/archived-news.json';
import { SITE } from '../../config/site';
import { buildPublicArticleModel, publicArticleIsPublishable } from '../../lib/publicArticleModel.js';
import {
  articleCanonicalPath,
  buildArticleStructuredData,
  shouldNoindexArticle,
} from '../../lib/seo-safeguards.js';

export function getStaticPaths() {
  return [...latestNews, ...archivedNews]
    .filter((article) =>
      article?.id
      && article['articlePagePublished'] !== false
      && article.public_status !== 'quarantined'
      && article.public_status !== 'archive_only_noindex'
      && article.archiveOnly !== true
      && !shouldNoindexArticle(article)
      && publicArticleIsPublishable(article)
    )
    .map((article) => ({
      params: { id: article.id },
      props: { article },
    }));
}

const { article } = Astro.props;
const articleRecord = article as any;
const publicArticle = buildPublicArticleModel(articleRecord);

if (!article || !publicArticle.ok) {
  throw new Error('Article not found');
}

const displayTitle = publicArticle.title;
const detailImage = articleRecord.sourceImage || articleRecord.generatedImage || SITE.defaultOgImage;
const canonicalPath = articleCanonicalPath(articleRecord);
const articleUrl = `${SITE.url}${canonicalPath}`;
const taxonomy = publicArticle.taxonomy;
const publicPresentation = publicArticle.publicPresentation;
const articleDescription = publicArticle.deck || articleRecord.title;
const sourceAttribution = publicArticle.sourceAttribution;
const noindexArticle = shouldNoindexArticle(articleRecord);
const articleBodyBlocks = publicArticle.articleBodyBlocks;
const atAGlanceItems = publicArticle.atAGlance;
const watchMetrics = publicArticle.whatToWatch;
const bottomLine = publicArticle.bottomLine;
const structuredData = buildArticleStructuredData({
  article: articleRecord,
  site: SITE,
  title: displayTitle,
  description: articleDescription,
  image: detailImage,
  canonicalUrl: articleUrl,
  taxonomy,
  articleBody: articleBodyBlocks,
});
---
<Layout
  title={`${displayTitle} | ${SITE.name}`}
  description={articleDescription}
  type="article"
  canonicalPath={canonicalPath}
  image={detailImage}
  noindex={noindexArticle}
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)}></script>
  <main class="detail-shell">
    <a class="back-link" href="/">Latest board</a>

    <article class="detail-card">
      <div class="detail-media detail-media-top">
        <img src={detailImage} alt={displayTitle} loading="eager" />
      </div>

      <div class="detail-body">
        <PublicArticleHeader
          title={displayTitle}
          deck={publicArticle.deck}
          byline={publicArticle.byline}
          sourceAttribution={sourceAttribution}
          taxonomy={taxonomy}
          presentation={publicPresentation}
          publishedAt={article.publishedAt}
        />

        <PublicAtAGlance items={atAGlanceItems} />

        <PublicArticleBody blocks={articleBodyBlocks} />

        <NewsletterCapture compact={true} />

        <PublicWhatToWatch items={watchMetrics} />

        <PublicBottomLine bottomLine={bottomLine} />

        <section class="detail-section source-attribution-panel">
          <h2>Source</h2>
          <p>
            Source link for verification: <strong>{sourceAttribution.name}</strong>
            {sourceAttribution.domain ? <> ({sourceAttribution.domain})</> : null}. Compute Current links to the original source for attribution and reader verification.
          </p>
          <p>
            <a href={sourceAttribution.url} target="_blank" rel="noopener noreferrer">
              Read the original source
            </a>
          </p>
          <p>
            Canonical page: <a href={articleUrl}>{articleUrl}</a>
          </p>
        </section>

        <section class="detail-section disclosure-panel">
          <h2>AI-assisted disclosure</h2>
          <p>
            {SITE.name} uses AI-assisted extraction, classification, summarization, and drafting workflows. The source article remains the authoritative record; this page is an editorial intelligence memo derived from that source and internal quality gates.
          </p>
          <p>
            Read the full <a href="/ai-disclosure/">AI-assisted content disclosure</a> and <a href="/methodology/">methodology</a>.
          </p>
        </section>

        {article.tags?.length ? (
          <div class="tag-row">
            {article.tags.map((tag) => (
              <span class="tag-pill">#{tag}</span>
            ))}
          </div>
        ) : null}

        <div class="detail-footer">
          <a class="detail-button" href="/">
            Browse latest board
          </a>
          <a class="source-cta" href={sourceAttribution.url} target="_blank" rel="noopener noreferrer">
            Read crawled source article
          </a>
        </div>
      </div>
    </article>
  </main>
</Layout>
