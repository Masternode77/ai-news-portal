---
import Layout from '../../layouts/Layout.astro';
import latestNews from '../../data/latest-news.json';
import archivedNews from '../../data/archived-news.json';
import { SITE } from '../../config/site';
import { cleanEditorialText, displayHeadline, executiveSummaryLines } from '../../lib/editorial-display.js';

export function getStaticPaths() {
  return [...latestNews, ...archivedNews]
    .filter((article) => article?.id && article['articlePagePublished'] !== false)
    .map((article) => ({
      params: { id: article.id },
      props: { article },
    }));
}

const { article } = Astro.props;

if (!article) {
  throw new Error('Article not found');
}

const lens = article.expertLensFull || null;
const lensTeaser = article.expertLensShort || article.expertLens || lens?.thesis || null;
const displayTitle = displayHeadline(article);
const detailImage = article.sourceImage || article.generatedImage || SITE.defaultOgImage;
const articleDescription = cleanEditorialText(lens?.metaDescription || article.summary || article.snippet || article.title);
const canonicalPath = `/news/${article.id}/`;
const articleUrl = `${SITE.url}${canonicalPath}`;
const executiveSummary = executiveSummaryLines(article);
const articleBody = (lens?.finalArticleBody || article.articleText || article.snippet || article.summary || '')
  .split(/\n{2,}/)
  .map((paragraph) => cleanEditorialText(paragraph))
  .filter((paragraph) => !/^(why it matters|pressure points|market implications|what to watch)$/i.test(paragraph))
  .filter(Boolean);
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: displayTitle,
  description: articleDescription,
  image: detailImage.startsWith('http') ? detailImage : `${SITE.url}${detailImage}`,
  datePublished: article.publishedAt,
  dateModified: article['updatedAt'] || article.publishedAt,
  author: {
    '@type': 'Organization',
    name: SITE.name,
  },
  publisher: {
    '@type': 'Organization',
    name: SITE.name,
  },
  mainEntityOfPage: articleUrl,
};
---
<Layout
  title={`${displayTitle} | ${SITE.name}`}
  description={articleDescription}
  type="article"
  canonicalPath={canonicalPath}
  image={detailImage}
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)}></script>
  <main class="detail-shell">
    <a class="back-link" href="/">Latest board</a>

    <article class="detail-card">
      <div class="detail-media detail-media-top">
        <img src={detailImage} alt={displayTitle} loading="eager" />
      </div>

      <div class="detail-body">
        <div class="meta-strip">
          <span class="category-badge">{article.category || 'Infrastructure'}</span>
          <span class="source-pill">{article.source}</span>
          <span class="region-pill">{article.region || 'Global'}</span>
          <time>{new Date(article.publishedAt).toLocaleString('en-US')}</time>
        </div>

        <h1>{displayTitle}</h1>
        <p class="detail-summary">{cleanEditorialText(lensTeaser || article.summary || article.snippet)}</p>

        {executiveSummary.length ? (
          <section class="executive-summary" aria-label="Executive summary">
            <span>Editor&apos;s Brief</span>
            <ol>
              {executiveSummary.map((line) => (
                <li>{line}</li>
              ))}
            </ol>
          </section>
        ) : null}

        {articleBody.length ? (
          <section class="detail-section detail-article-copy">
            {articleBody.map((paragraph) => (
              <p>{paragraph}</p>
            ))}
          </section>
        ) : null}

        <section class="detail-section">
          <h2>Source</h2>
          <p>
            <a href={lens?.sourceLink || article.sourceUrl || article.url} target="_blank" rel="noreferrer">
              Read the original report
            </a>
          </p>
        </section>

        {article.tags?.length ? (
          <div class="tag-row">
            {article.tags.map((tag) => (
              <span class="tag-pill">#{tag}</span>
            ))}
          </div>
        ) : null}

        <div class="detail-footer">
          <a class="detail-button" href="/">
            Browse latest board
          </a>
          <a class="source-cta" href={article.sourceUrl || article.url} target="_blank" rel="noreferrer">
            Read crawled source article
          </a>
        </div>
      </div>
    </article>
  </main>
</Layout>
