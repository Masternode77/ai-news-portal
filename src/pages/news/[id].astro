---
import Layout from '../../layouts/Layout.astro';
import ArticleHeader from '../../components/ArticleHeader.astro';
import ArticleHeroImage from '../../components/ArticleHeroImage.astro';
import LongformArticleBody from '../../components/LongformArticleBody.astro';
import SourceAttribution from '../../components/SourceAttribution.astro';
import AIDisclosureFooter from '../../components/AIDisclosureFooter.astro';
import RelatedArticles from '../../components/RelatedArticles.astro';
import latestNews from '../../data/latest-news.json';
import archivedNews from '../../data/archived-news.json';
import { SITE } from '../../config/site';
import { cleanEditorialText, displayHeadline } from '../../lib/editorial-display.js';
import { buildPublicPresentation } from '../../lib/publicPresentation.js';
import { taxonomyDisplay } from '../../lib/taxonomy-display.js';
import {
  articleCanonicalPath,
  buildArticleStructuredData,
  sourceAttributionFor,
} from '../../lib/seo-safeguards.js';
import { forbiddenPublicPhraseMatches, guardPublicCopy } from '../../../scripts/lib/copy-quality-guard.mjs';
import { routePublicLane } from '../../../scripts/lib/public-lane-router.mjs';
import { cleanArticleBodyBlocks } from '../../../scripts/lib/article-body-cleaner.mjs';
import { buildHomepageFeed } from '../../../scripts/lib/homepage-feed-builder.mjs';
import { isPublicLongformArticle } from '../../../scripts/lib/public-surface-eligibility.mjs';
import {
  articleHeroImage,
  articleImageAlt,
  articleImageProvenance,
  articleOpenGraphImage,
} from '../../../scripts/lib/article-image-surface.mjs';
import { relatedArticlesFor } from '../../../scripts/lib/related-articles.mjs';

export function getStaticPaths() {
  const allArticles = [...latestNews, ...archivedNews];
  const seenArticleIds = new Set<string>();

  return allArticles
    .filter(isPublicLongformArticle)
    .filter((article) => {
      if (seenArticleIds.has(article.id)) {
        return false;
      }
      seenArticleIds.add(article.id);
      return true;
    })
    .map((article) => ({
      params: { id: article.id },
      props: { article },
    }));
}

const allArticles = [...latestNews, ...archivedNews];

const { article } = Astro.props;
const articleRecord = article as any;

if (!article) {
  throw new Error('Article not found');
}

const displayTitle = displayHeadline(articleRecord);
const publicRouting = articleRecord.public_routing || routePublicLane(articleRecord);
const publicPresentation = buildPublicPresentation(articleRecord, { route: publicRouting });
const detailImage = articleHeroImage(articleRecord) || SITE.defaultOgImage;
const detailImageProvenance = articleImageProvenance(articleRecord, 'hero');
const openGraphImage = articleOpenGraphImage(articleRecord) || detailImage;
const canonicalPath = articleCanonicalPath(articleRecord);
const articleUrl = `${SITE.url}${canonicalPath}`;
const taxonomy = taxonomyDisplay(articleRecord);
const sourceAttribution = sourceAttributionFor(articleRecord);
const articleDescription = guardPublicCopy(cleanEditorialText(
  publicPresentation.deck
  || articleRecord.expertLensFull?.metaDescription
  || articleRecord.summary
  || articleRecord.snippet
  || articleRecord.title
)).text;
const articleBodyBlocks = cleanArticleBodyBlocks(articleRecord.expertLensFull?.finalArticleBody || '')
  .map((paragraph: string) => guardPublicCopy(cleanEditorialText(paragraph)).text)
  .filter((paragraph: string) => !forbiddenPublicPhraseMatches(paragraph).length)
  .filter(Boolean);
const relatedCandidates = relatedArticlesFor(
  articleRecord,
  allArticles.filter((item: any) => isPublicLongformArticle(item)),
  { limit: 8 }
);
const relatedDecorated = buildHomepageFeed(relatedCandidates, { limit: relatedCandidates.length, minimumVisible: 0 }).items;
const relatedById = new Map(relatedDecorated.map((item: any) => [item.id, item]));
const related = relatedCandidates
  .map((item: any) => relatedById.get(item.id))
  .filter(Boolean)
  .slice(0, 3);
const structuredData = buildArticleStructuredData({
  article: articleRecord,
  site: SITE,
  title: displayTitle,
  description: articleDescription,
  image: openGraphImage,
  canonicalUrl: articleUrl,
  taxonomy,
  articleBody: articleBodyBlocks,
});
---
<Layout
  title={`${displayTitle} | ${SITE.name}`}
  description={articleDescription}
  type="article"
  canonicalPath={canonicalPath}
  image={openGraphImage}
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)}></script>
  <main class="detail-shell publication-article">
    <article class="detail-card publication-article-card">
      <div class="detail-body">
        <ArticleHeader
          category={taxonomy.primary}
          date={articleRecord.analysisPublishedAt || articleRecord.publishedAt}
          source={sourceAttribution}
          title={displayTitle}
          deck={publicPresentation.deck || articleDescription}
        />

        <ArticleHeroImage
          image={detailImage}
          imageAlt={publicPresentation.image_alt || articleImageAlt({ ...articleRecord, title: displayTitle })}
          provenanceLabel={detailImageProvenance.label}
          provenanceKind={detailImageProvenance.kind}
          caption={sourceAttribution.name ? `Visual analysis for reporting from ${sourceAttribution.name}.` : ''}
        />

        {articleBodyBlocks.length ? <LongformArticleBody blocks={articleBodyBlocks} /> : null}

        <SourceAttribution source={sourceAttribution} />

        <AIDisclosureFooter canonicalUrl={articleUrl} />

        {article.tags?.length ? (
          <div class="tag-row" aria-label="Tags">
            {article.tags.map((tag: string) => (
              <span class="tag-pill">#{tag}</span>
            ))}
          </div>
        ) : null}

        <RelatedArticles articles={related} currentId={articleRecord.id} />
      </div>
    </article>
  </main>
</Layout>
