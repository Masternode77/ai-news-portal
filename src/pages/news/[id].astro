---
import Layout from '../../layouts/Layout.astro';
import latestNews from '../../data/latest-news.json';
import archivedNews from '../../data/archived-news.json';

export function getStaticPaths() {
  return [...latestNews, ...archivedNews]
    .filter((article) => article?.id)
    .map((article) => ({
      params: { id: article.id },
      props: { article },
    }));
}

const { article } = Astro.props;

if (!article) {
  throw new Error('Article not found');
}

const lens = article.expertLensFull || null;
const lensTeaser = article.expertLensShort || article.expertLens || lens?.thesis || null;
const lensSections = [
  ['What happened', lens?.whatHappened],
  ['Why this matters', lens?.whyThisMatters],
  ['What the market may be missing', lens?.marketMissing],
  ['Implications for investors', lens?.investors],
  ['Implications for operators', lens?.operators],
  ['Implications for hyperscalers', lens?.hyperscalers],
  ['What to watch next', lens?.watchNext],
].filter(([, value]) => Boolean(value));
const articleBody = (lens?.finalArticleBody || article.articleText || article.snippet || article.summary || '')
  .split(/\n{2,}/)
  .map((paragraph) => paragraph.replace(/\s+/g, ' ').trim())
  .filter(Boolean);
---
<Layout title={article.title} description={article.summary || article.snippet || article.title}>
  <main class="detail-shell">
    <a class="back-link" href="/">Back to board</a>

    <article class="detail-card panel">
      <div class="detail-media">
        <img src={article.generatedImage || '/generated/default.svg'} alt={article.title} loading="eager" />
      </div>

      <div class="detail-body">
        <div class="meta-strip">
          <span class="category-badge">{article.category || 'Infrastructure'}</span>
          <span class="source-pill">{article.source}</span>
          <span class="region-pill">{article.region || 'Global'}</span>
          <time>{new Date(article.publishedAt).toLocaleString('en-US')}</time>
        </div>

        <h1>{article.title}</h1>
        <p class="detail-summary">{article.summary || article.snippet}</p>

        {lensTeaser ? (
          <section class="detail-lens">
            <span>One-line thesis</span>
            <p>{lensTeaser}</p>
          </section>
        ) : null}

        {lensSections.map(([title, value]) => (
          <section class="detail-section">
            <h2>{title}</h2>
            <p>{value}</p>
          </section>
        ))}

        {lens?.headlineOptions?.length ? (
          <section class="detail-section">
            <h2>Headline options 5개</h2>
            <ol class="headline-list">
              {lens.headlineOptions.map((headline) => (
                <li>{headline}</li>
              ))}
            </ol>
          </section>
        ) : null}

        {lens?.finalHeadline ? (
          <section class="detail-section">
            <h2>Final headline</h2>
            <p>{lens.finalHeadline}</p>
          </section>
        ) : null}

        {lens?.metaDescription ? (
          <section class="detail-section">
            <h2>Meta description</h2>
            <p>{lens.metaDescription}</p>
          </section>
        ) : null}

        {articleBody.length ? (
          <section class="detail-section">
            <h2>Final article body</h2>
            {articleBody.map((paragraph) => (
              <p>{paragraph}</p>
            ))}
          </section>
        ) : null}

        <section class="detail-section">
          <h2>Source link</h2>
          <p>
            <a href={lens?.sourceLink || article.sourceUrl || article.url} target="_blank" rel="noreferrer">
              {lens?.sourceLink || article.sourceUrl || article.url}
            </a>
          </p>
        </section>

        {article.tags?.length ? (
          <div class="tag-row">
            {article.tags.map((tag) => (
              <span class="tag-pill">#{tag}</span>
            ))}
          </div>
        ) : null}

        <div class="detail-footer">
          <a class="detail-button" href="/">
            Browse latest board
          </a>
          <a class="source-cta" href={article.sourceUrl || article.url} target="_blank" rel="noreferrer">
            Read crawled source article
          </a>
        </div>
      </div>
    </article>
  </main>
</Layout>
