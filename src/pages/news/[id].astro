---
import Layout from '../../layouts/Layout.astro';
import latestNews from '../../data/latest-news.json';
import archivedNews from '../../data/archived-news.json';
import { SITE } from '../../config/site';
import { cleanEditorialText, displayHeadline, executiveSummaryLines } from '../../lib/editorial-display.js';
import { buildPublicPresentation } from '../../lib/publicPresentation.js';
import { taxonomyDisplay } from '../../lib/taxonomy-display.js';
import {
  articleCanonicalPath,
  articleNoindexReasons,
  buildArticleStructuredData,
  shouldNoindexArticle,
  sourceAttributionFor,
} from '../../lib/seo-safeguards.js';
import { forbiddenPublicPhraseMatches, guardPublicCopy } from '../../../scripts/lib/copy-quality-guard.mjs';
import { routePublicLane } from '../../../scripts/lib/public-lane-router.mjs';

export function getStaticPaths() {
  return [...latestNews, ...archivedNews]
    .filter((article) => article?.id && article['articlePagePublished'] !== false)
    .map((article) => ({
      params: { id: article.id },
      props: { article },
    }));
}

const { article } = Astro.props;
const articleRecord = article as any;

if (!article) {
  throw new Error('Article not found');
}

const lens = article.expertLensFull || null;
const lensTeaser = article.expertLensShort || article.expertLens || lens?.thesis || null;
const displayTitle = displayHeadline(article);
const detailImage = article.sourceImage || article.generatedImage || SITE.defaultOgImage;
const canonicalPath = articleCanonicalPath(article);
const articleUrl = `${SITE.url}${canonicalPath}`;
const executiveSummary = executiveSummaryLines(article)
  .map((line) => guardPublicCopy(line).text)
  .filter((line) => !forbiddenPublicPhraseMatches(line).length)
  .slice(0, 3);
const executiveSummaryLabel = lens?.dynamicBriefLabel || article.dynamic_brief_label || article.narrative_dna?.brief_label || 'Operator Note';
const taxonomy = taxonomyDisplay(articleRecord);
const publicRouting = article.public_routing || routePublicLane(articleRecord);
const publicPresentation = buildPublicPresentation(articleRecord, { route: publicRouting });
const articleDescription = cleanEditorialText(publicPresentation.deck || lens?.metaDescription || article.summary || article.snippet || article.title);
const sourceAttribution = sourceAttributionFor(articleRecord);
const noindexReasons = articleNoindexReasons(articleRecord);
const noindexArticle = shouldNoindexArticle(articleRecord);
const articleBodyBlocks = (lens?.finalArticleBody || article.articleText || article.snippet || article.summary || '')
  .split(/\n{2,}/)
  .map((paragraph) => guardPublicCopy(cleanEditorialText(paragraph)).text)
  .filter((paragraph) => !/^(why it matters|pressure points|market implications|what to watch)$/i.test(paragraph))
  .filter((paragraph) => !forbiddenPublicPhraseMatches(paragraph).length)
  .filter(Boolean);
const isBodyHeading = (paragraph: string) =>
  paragraph.length <= 72 &&
  !/[.!?]$/.test(paragraph) &&
  /^[A-Z0-9][A-Za-z0-9 &:/+-]+$/.test(paragraph);
const structuredData = buildArticleStructuredData({
  article: articleRecord,
  site: SITE,
  title: displayTitle,
  description: articleDescription,
  image: detailImage,
  canonicalUrl: articleUrl,
  taxonomy,
  articleBody: articleBodyBlocks,
});
---
<Layout
  title={`${displayTitle} | ${SITE.name}`}
  description={articleDescription}
  type="article"
  canonicalPath={canonicalPath}
  image={detailImage}
  noindex={noindexArticle}
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)}></script>
  <main class="detail-shell">
    <a class="back-link" href="/">Latest board</a>

    <article class="detail-card">
      <div class="detail-media detail-media-top">
        <img src={detailImage} alt={displayTitle} loading="eager" />
      </div>

      <div class="detail-body">
        <div class="meta-strip">
          <span class="category-badge">{taxonomy.primary}</span>
          <span class="source-pill">{publicPresentation.signal_label}</span>
          <span class="region-pill">{publicPresentation.region}</span>
          <time>{new Date(article.publishedAt).toLocaleString('en-US')}</time>
        </div>

        <h1>{displayTitle}</h1>
        <p class="detail-summary">{publicPresentation.deck || cleanEditorialText(lensTeaser || article.summary || article.snippet)}</p>

        <section class="taxonomy-panel" aria-label="Infrastructure taxonomy">
          <div>
            <span>Signal</span>
            <strong>{publicPresentation.signal_label}</strong>
          </div>
          <div>
            <span>Editorial Lens</span>
            <strong>{publicPresentation.editorial_lens}</strong>
          </div>
          <div>
            <span>Layer</span>
            <strong>{taxonomy.layer}</strong>
          </div>
          <div>
            <span>Type</span>
            <strong>{taxonomy.articleType}</strong>
          </div>
          <div>
            <span>Region</span>
            <strong>{publicPresentation.region}</strong>
          </div>
          {publicPresentation.reader_impact.length ? (
            <div class="taxonomy-panel-wide">
              <span>Reader Impact</span>
              <strong>{publicPresentation.reader_impact.join(', ')}</strong>
            </div>
          ) : null}
        </section>

        <section class="detail-section public-why-panel">
          <h2>Editorial Read</h2>
          <p>{publicPresentation.why_it_matters}</p>
        </section>

        {executiveSummary.length ? (
          <section class="executive-summary" aria-label="Executive summary">
            <span>{executiveSummaryLabel}</span>
            <ol>
              {executiveSummary.map((line) => (
                <li>{line}</li>
              ))}
            </ol>
          </section>
        ) : null}

        {articleBodyBlocks.length ? (
          <section class="detail-section detail-article-copy">
            {articleBodyBlocks.map((paragraph) => (
              isBodyHeading(paragraph) ? <h2>{paragraph}</h2> : <p>{paragraph}</p>
            ))}
          </section>
        ) : null}

        <section class="detail-section disclosure-panel">
          <h2>AI-assisted disclosure</h2>
          <p>
            {SITE.name} uses AI-assisted extraction, classification, summarization, and drafting workflows. The source article remains the authoritative record; this page is an editorial intelligence memo derived from that source and internal quality gates.
          </p>
          <p>
            Read the full <a href="/ai-disclosure/">AI-assisted content disclosure</a> and <a href="/methodology/">methodology</a>.
          </p>
          <p>
            Canonical page: <a href={articleUrl}>{articleUrl}</a>
          </p>
          {noindexReasons.length ? (
            <p>
              Search indexing is disabled for this generated page because: {noindexReasons.join(', ')}.
            </p>
          ) : null}
        </section>

        <section class="detail-section source-attribution-panel">
          <h2>Source</h2>
          <p>
            Analysis is based on reporting from <strong>{sourceAttribution.name}</strong>
            {sourceAttribution.domain ? <> ({sourceAttribution.domain})</> : null}. Compute Current links to the original source for attribution and reader verification.
          </p>
          <p>
            <a href={sourceAttribution.url} target="_blank" rel="noopener noreferrer">
              Read the original source
            </a>
          </p>
        </section>

        {article.tags?.length ? (
          <div class="tag-row">
            {article.tags.map((tag) => (
              <span class="tag-pill">#{tag}</span>
            ))}
          </div>
        ) : null}

        <div class="detail-footer">
          <a class="detail-button" href="/">
            Browse latest board
          </a>
          <a class="source-cta" href={sourceAttribution.url} target="_blank" rel="noopener noreferrer">
            Read crawled source article
          </a>
        </div>
      </div>
    </article>
  </main>
</Layout>
