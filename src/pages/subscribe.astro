---
import Layout from '../layouts/Layout.astro';
import NewsletterCapture from '../components/NewsletterCapture.astro';
import { SITE } from '../config/site';
---
<Layout
  title={`Subscribe | ${SITE.name}`}
  description="Subscribe to the Daily AI Infrastructure Brief."
  canonicalPath="/subscribe/"
>
  <main class="policy-shell">
    <a class="back-link" href="/">Latest board</a>
    <section class="policy-page">
      <p class="eyebrow">Daily AI Infrastructure Brief</p>
      <h1>Power, capacity, silicon, cooling, cloud, capital, and policy signals behind the AI buildout.</h1>
      <p class="policy-lede">
        A concise briefing for operators, investors, cloud capacity teams, developers, and infrastructure strategists tracking the constraints behind AI deployment.
      </p>
    </section>
    <NewsletterCapture />
  </main>
</Layout>
