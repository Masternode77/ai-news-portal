---
import Layout from '../layouts/Layout.astro';
import { SITE } from '../config/site';

const routes = SITE.commercial.routes;
---
<Layout
  title={`Publication Feed | ${SITE.name}`}
  description="Open Compute Current publication feed for power, capacity, chips, cooling, cloud demand, capital, and APAC/Korea infrastructure coverage."
  canonicalPath={routes.subscribe}
  noindex={true}
>
  <main class="policy-shell commercial-page commercial-page-subscribe">
    <a class="back-link" href="/">Latest analysis</a>
    <article class="policy-page commercial-article">
      <header class="commercial-hero">
        <div>
          <p class="eyebrow">Publication feed</p>
          <h1>AI infrastructure signals for capacity, power, and capital decisions.</h1>
          <p class="policy-lede">
            The public board gives infrastructure readers a disciplined read on the bottlenecks shaping AI data
            center deployment, with source links and editorial confidence notes attached.
          </p>
        </div>

        <aside class="commercial-hero-note" aria-label="Brief output">
          <span>Output</span>
          <strong>Source-linked public read</strong>
          <p>Constraint signals, watch items, and confidence notes without a signup wall.</p>
        </aside>
      </header>

      <nav class="commercial-actions" aria-label="Publication feed actions">
        <a href={routes.archive}>{SITE.commercial.ctas.weeklyBrief}</a>
        <a href={routes.sample}>Read a Sample</a>
        <a href={routes.rss}>RSS Feed</a>
      </nav>

      <section class="commercial-section">
        <div class="commercial-section-heading">
          <p class="eyebrow">Coverage lanes</p>
          <h2>What the publication feed tracks</h2>
        </div>
        <ul class="commercial-signal-list commercial-check-grid">
          <li>Power availability, grid interconnection, generation tie-ups, and site constraints.</li>
          <li>Data center capacity, hyperscaler demand, cloud commitments, and lease movement.</li>
          <li>Chips, rack density, liquid cooling, supply bottlenecks, and deployment timing.</li>
          <li>Capital, project finance, policy, permitting, and APAC/Korea-relevant market movement.</li>
        </ul>
      </section>

      <section class="commercial-section commercial-proof-grid">
        <div class="commercial-note">
          <h2>How access works</h2>
          <p>
            The archive and RSS feed remain open so readers can follow published signals without a signup wall.
          </p>
        </div>
        <div class="commercial-note">
          <h2>What it reduces</h2>
          <p>
            A scattered watchlist across power, data center, chip, cloud, cooling, policy, and capital sources.
          </p>
        </div>
      </section>

      <nav class="policy-link-row" aria-label="Public reference pages">
        <a href={routes.archive}>Archive</a>
        <a href={routes.sample}>Sample</a>
        <a href="/search/">Search</a>
      </nav>
    </article>
  </main>
</Layout>
