---
import Layout from '../layouts/Layout.astro';
import { SITE } from '../config/site';
import { PRICING_FEATURES, SUBSCRIPTION_TIERS, formatTierPrice } from '../../scripts/lib/subscription-tiers.mjs';
---
<Layout
  title={`Pricing | ${SITE.name}`}
  description="Pricing for Compute Current Free, Pro, Team, and Enterprise AI infrastructure intelligence plans."
  canonicalPath="/pricing/"
>
  <main class="product-shell" data-page-event="pricing_view">
    <section class="product-hero">
      <p class="eyebrow">Pricing</p>
      <h1>AI infrastructure intelligence for readers, teams, and enterprise operators.</h1>
      <p>
        Start with the free signal board and Daily Brief. Upgrade when you need analyst memos, premium archives, market maps, alerts, or custom intelligence.
      </p>
    </section>

    <section class="pricing-grid" aria-label="Pricing tiers">
      {SUBSCRIPTION_TIERS.map((tier) => (
        <article class:list={['pricing-card', tier.id === 'pro' && 'pricing-card-featured']}>
          <p class="eyebrow">{tier.name}</p>
          <h2>{formatTierPrice(tier)}</h2>
          {tier.priceYearly ? <p class="price-note">${tier.priceYearly}/year</p> : null}
          <p>{tier.audience}</p>
          <a
            href={tier.href}
            data-analytics-event={tier.id === 'enterprise' || tier.id === 'team' ? 'enterprise_cta_click' : tier.id === 'pro' ? 'pro_cta_click' : 'newsletter_signup_view'}
            data-analytics-label={`${tier.name} pricing CTA`}
          >
            {tier.cta}
          </a>
        </article>
      ))}
    </section>

    <section class="comparison-table" aria-label="Plan comparison">
      <div class="comparison-row comparison-head">
        <span>Feature</span>
        {SUBSCRIPTION_TIERS.map((tier) => <strong>{tier.name}</strong>)}
      </div>
      {PRICING_FEATURES.map(([key, label]) => (
        <div class="comparison-row">
          <span>{label}</span>
          {SUBSCRIPTION_TIERS.map((tier) => {
            const value = tier.features[key];
            return <strong>{value === true ? 'Yes' : value === false ? 'No' : value}</strong>;
          })}
        </div>
      ))}
    </section>
  </main>
</Layout>
