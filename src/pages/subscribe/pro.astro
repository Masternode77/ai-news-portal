---
import Layout from '../../layouts/Layout.astro';
import { SITE } from '../../config/site';
---
<Layout
  title={`Pro Subscription | ${SITE.name}`}
  description="Join Compute Current Pro for weekly analyst memos, market maps, premium archive access, and PDF briefings."
  canonicalPath="/subscribe/pro/"
>
  <main class="product-shell">
    <section class="product-hero">
      <p class="eyebrow">Pro</p>
      <h1>Turn the free signal board into a weekly intelligence workflow.</h1>
      <p>
        Pro is built for infrastructure readers who need full memo access, premium archive depth, market maps, and downloadable briefings.
      </p>
    </section>
    <section class="product-band">
      <div>
        <h2>Payment integration is coming next.</h2>
        <p>
          Compute Current is subscription-ready, but checkout is not enabled in this environment. Join the waitlist and we will send Pro access details.
        </p>
      </div>
      <form class="conversion-form" data-form-name="pro-waitlist" data-analytics-submit="pro_cta_click">
        <label>
          <span>Email</span>
          <input type="email" name="email" required placeholder="you@company.com" />
        </label>
        <label>
          <span>Company</span>
          <input type="text" name="company" placeholder="Company" />
        </label>
        <button type="submit">Join Pro waitlist</button>
        <p class="form-status" data-form-status></p>
      </form>
    </section>
  </main>
</Layout>
