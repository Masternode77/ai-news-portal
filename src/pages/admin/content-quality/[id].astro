---
import Layout from '../../../layouts/Layout.astro';
import InternalQualityPanel from '../../../components/InternalQualityPanel.astro';
import AdminEvidenceBox from '../../../components/admin/AdminEvidenceBox.astro';
import AdminClaimVerificationNote from '../../../components/admin/AdminClaimVerificationNote.astro';
import latestNews from '../../../data/latest-news.json';
import archivedNews from '../../../data/archived-news.json';
import { SITE } from '../../../config/site';
import { buildAdminQualityModel } from '../../../lib/adminQualityModel.js';

export function getStaticPaths() {
  return ([...latestNews, ...archivedNews] as any[])
    .filter((article) => article?.id)
    .map((article) => ({
      params: { id: article.id },
      props: { article },
    }));
}

const { article } = Astro.props;
const articleRecord = article as any;
const quality = buildAdminQualityModel(articleRecord);
---
<Layout
  title={`Quality: ${articleRecord.title} | ${SITE.name}`}
  description="Private Compute Current content quality detail"
  canonicalPath={`/admin/content-quality/${articleRecord.id}/`}
  noindex={true}
>
  <main class="admin-shell">
    <header class="admin-header">
      <a class="back-link admin-back" href="/admin/content-quality/">Content quality</a>
      <div>
        <p class="eyebrow">Admin Debug</p>
        <h1>{articleRecord.title}</h1>
      </div>
      <p class="admin-deck">{articleRecord.source} · {articleRecord.sourceUrl || articleRecord.url}</p>
    </header>

    <section class="admin-panel">
      <InternalQualityPanel quality={quality} />
    </section>

    {articleRecord.backfilledAnalysis ? (
      <section class="admin-panel">
        <p class="eyebrow">Backfilled Analysis</p>
      </section>
    ) : null}

    <section class="admin-panel">
      <AdminEvidenceBox evidence={quality.evidence} claimSummary={quality.claim_ledger_summary} />
    </section>

    <section class="admin-panel">
      <AdminClaimVerificationNote claims={quality.claim_ledger} />
    </section>
  </main>
</Layout>
