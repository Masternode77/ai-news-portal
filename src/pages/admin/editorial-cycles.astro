---
import Layout from '../../layouts/Layout.astro';
import cycles from '../../data/editorial-cycles.json';
import clusters from '../../data/signal-clusters.json';
import claims from '../../data/claim-ledger.json';
import sourceHealth from '../../data/source-health.json';
import { buildAdminEditorialCycleModel } from '../../../scripts/lib/admin-editorial-cycle-model.mjs';

const model = buildAdminEditorialCycleModel({ cycles, clusters, claims, sourceHealth });
---
<Layout title="Editorial Cycles Admin" noindex={true}>
  <main class="admin-shell">
    <header class="admin-header">
      <a class="admin-back" href="/admin/content-quality/">Content quality</a>
      <h1>Editorial Cycles</h1>
      <p class="admin-deck">Internal autonomous desk status, selection, and quality gate diagnostics.</p>
    </header>
    <section class="admin-panel">
      <h2>Latest Cycle</h2>
      <pre>{JSON.stringify(model.latest || {}, null, 2)}</pre>
    </section>
    <section class="admin-panel">
      <h2>Recent Cycles</h2>
      <div class="quality-list">
        {model.cycles.map((cycle) => (
          <article class="quality-list-item">
            <h3><a href={`/admin/editorial-cycles/${cycle.cycle_id}/`}>{cycle.cycle_id}</a></h3>
            <p>{cycle.status} · published {cycle.published_analyses?.length || 0} · held {cycle.held_signals?.length || 0}</p>
          </article>
        ))}
      </div>
    </section>
  </main>
</Layout>
