---
import Layout from '../../../layouts/Layout.astro';
import latestNews from '../../../data/latest-news.json';
import archivedNews from '../../../data/archived-news.json';
import { SITE } from '../../../config/site';

export function getStaticPaths() {
  return [...latestNews, ...archivedNews]
    .filter((article) => article?.id)
    .map((article) => ({
      params: { id: article.id },
      props: {
        articleId: article.id,
        fallbackTitle: article.expertLensFull?.finalHeadline || article.title || article.id,
      },
    }));
}

const { articleId, fallbackTitle } = Astro.props;
---
<Layout
  title={`Edit ${fallbackTitle} | ${SITE.name}`}
  description="Private Compute Current article editor"
  canonicalPath={`/admin/edit/${articleId}/`}
  noindex={true}
>
  <main class="admin-shell" data-article-id={articleId}>
    <header class="admin-header">
      <a class="back-link admin-back" href={`/news/${articleId}/`}>View public article</a>
      <div>
        <p class="eyebrow">Private Editor</p>
        <h1>Compute Current article edit</h1>
      </div>
      <p class="admin-deck">Sign in to edit the article copy stored in GitHub. Saving creates a commit on the configured branch and lets Vercel rebuild the public page.</p>
    </header>

    <section id="admin-login" class="admin-panel">
      <div>
        <p class="eyebrow">Admin Login</p>
        <h2>Restricted access</h2>
      </div>
      <form class="admin-form" id="login-form">
        <label>
          <span>Username</span>
          <input name="username" autocomplete="username" />
        </label>
        <label>
          <span>Password</span>
          <input name="password" type="password" autocomplete="current-password" required />
        </label>
        <button type="submit">Sign in</button>
      </form>
    </section>

    <section id="admin-editor" class="admin-panel admin-editor" hidden>
      <div class="admin-editor-top">
        <div>
          <p class="eyebrow">Article</p>
          <h2 id="editor-title">{fallbackTitle}</h2>
        </div>
        <button id="logout-button" class="admin-secondary" type="button">Sign out</button>
      </div>

      <form class="admin-form admin-edit-form" id="article-form">
        <label>
          <span>Headline</span>
          <input name="title" required />
        </label>

        <input id="editor-action" name="action" type="hidden" value="save-draft" />

        <label>
          <span>Deck summary</span>
          <textarea name="dek" rows="3"></textarea>
        </label>

        <label>
          <span>Editor's read</span>
          <textarea name="expertLensShort" rows="3"></textarea>
        </label>

        <label>
          <span>Article body</span>
          <textarea name="bodyMarkdown" rows="18" required></textarea>
        </label>

        <div class="admin-field-grid">
          <label>
            <span>Category</span>
            <input name="category" />
          </label>
          <label>
            <span>Region</span>
            <input name="region" />
          </label>
          <label>
            <span>Source</span>
            <input name="source" />
          </label>
          <label>
            <span>Source URL</span>
            <input name="sourceUrl" type="url" />
          </label>
          <label>
            <span>Published at</span>
            <input name="publishedAt" />
          </label>
          <label>
            <span>Public status</span>
            <select name="public_status">
              <option value="draft">Draft</option>
              <option value="published">Published</option>
              <option value="hidden">Hidden</option>
              <option value="noindex">Noindex</option>
            </select>
          </label>
        </div>

        <label>
          <span>Tags</span>
          <input name="tags" placeholder="power, chips, cloud" />
        </label>

        <label>
          <span>Meta description</span>
          <textarea name="metaDescription" rows="2"></textarea>
        </label>

        <label>
          <span>Canonical URL</span>
          <input name="canonicalUrl" type="url" />
        </label>

        <label>
          <span>Source image URL</span>
          <input name="sourceImage" />
        </label>

        <label>
          <span>Generated image path</span>
          <input name="generatedImage" placeholder="/generated/example.jpg" />
        </label>

        <div class="admin-field-grid">
          <label>
            <span>Hero image</span>
            <input name="heroImage" placeholder="/generated/articles/example/hero.webp" />
          </label>
          <label>
            <span>Thumbnail image</span>
            <input name="thumbnailImage" placeholder="/generated/articles/example/thumb.webp" />
          </label>
        </div>

        <label>
          <span>Image alt text</span>
          <input name="imageAlt" />
        </label>

        <label>
          <span>Image prompt</span>
          <textarea name="imagePrompt" rows="3"></textarea>
        </label>

        <label>
          <span>Replacement image path</span>
          <input name="replacementImage" placeholder="/uploads/replacement.webp" />
        </label>

        <div class="admin-save-row">
          <div id="article-meta" class="admin-meta"></div>
          <button type="submit" data-action="save-draft">Save draft</button>
        </div>

        <div class="admin-action-row" aria-label="Article actions">
          <button type="submit" data-action="publish">Publish</button>
          <button type="submit" data-action="hide">Hide</button>
          <button type="submit" data-action="noindex">Noindex</button>
          <button type="submit" data-action="regenerate-article">Regenerate article</button>
          <button type="submit" data-action="regenerate-brief">Regenerate brief</button>
          <button type="submit" data-action="regenerate-image">Regenerate image</button>
          <button type="submit" data-action="upload-image">Use replacement image</button>
          <button type="button" data-action="preview">Preview</button>
        </div>
      </form>

      <section id="admin-preview" class="admin-preview" aria-live="polite"></section>
    </section>

    <p id="admin-status" class="admin-status" role="status" aria-live="polite"></p>
  </main>

  <script>
    // @ts-nocheck
    const shell = document.querySelector('.admin-shell');
    const articleId = shell?.getAttribute('data-article-id') || '';
    const loginPanel = document.getElementById('admin-login');
    const editorPanel = document.getElementById('admin-editor');
    const loginForm = document.getElementById('login-form');
    const articleForm = document.getElementById('article-form');
    const status = document.getElementById('admin-status');
    const meta = document.getElementById('article-meta');
    const editorTitle = document.getElementById('editor-title');
    const logoutButton = document.getElementById('logout-button');
    const actionInput = document.getElementById('editor-action');
    const preview = document.getElementById('admin-preview');
    let csrfToken = '';

    const setStatus = (message, type = '') => {
      if (!status) return;
      status.textContent = message;
      status.dataset.type = type;
    };

    const field = (name) => articleForm?.elements.namedItem(name);
    const setField = (name, value) => {
      const control = field(name);
      if (control) control.value = value || '';
    };
    const getField = (name) => field(name)?.value || '';

    const requestJson = async (url, options = {}) => {
      const method = String(options.method || 'GET').toUpperCase();
      const headers = {
        'Content-Type': 'application/json',
        ...(options.headers || {}),
      };
      if (!['GET', 'HEAD', 'OPTIONS'].includes(method) && csrfToken) {
        headers['X-CSRF-Token'] = csrfToken;
      }
      const response = await fetch(url, {
        ...options,
        headers,
      });
      const payload = await response.json().catch(() => ({}));
      if (!response.ok) throw new Error(payload.error || 'Request failed.');
      return payload;
    };

    const fillForm = (article) => {
      if (!articleForm) return;
      setField('title', article.title || '');
      setField('dek', article.dek || article.deck || article.summary || '');
      setField('expertLensShort', article.expertLensShort || '');
      setField('bodyMarkdown', article.bodyMarkdown || article.finalArticleBody || '');
      setField('category', article.category || '');
      setField('region', article.region || '');
      setField('source', article.source || '');
      setField('sourceUrl', article.sourceUrl || '');
      setField('publishedAt', article.publishedAt || '');
      setField('public_status', article.public_status || article.status || 'draft');
      setField('tags', (article.tags || []).join(', '));
      setField('metaDescription', article.metaDescription || '');
      setField('canonicalUrl', article.canonicalUrl || '');
      setField('sourceImage', article.sourceImage || '');
      setField('generatedImage', article.generatedImage || '');
      setField('heroImage', article.heroImage || '');
      setField('thumbnailImage', article.thumbnailImage || '');
      setField('imageAlt', article.imageAlt || '');
      setField('imagePrompt', article.imagePrompt || '');
      setField('replacementImage', '');
      if (editorTitle) editorTitle.textContent = article.title || article.id;
      if (meta) {
        const published = article.publishedAt ? new Date(article.publishedAt).toLocaleString('en-US') : 'Unknown date';
        meta.textContent = `${article.source || 'Unknown source'} · ${published} · ${article.public_status || article.status || 'draft'}`;
      }
      renderPreviewFromForm();
    };

    const escapeHtml = (value) => String(value || '')
      .replaceAll('&', '&amp;')
      .replaceAll('<', '&lt;')
      .replaceAll('>', '&gt;')
      .replaceAll('"', '&quot;')
      .replaceAll("'", '&#39;');

    const renderPreviewFromForm = () => {
      if (!articleForm || !preview) return;
      const title = escapeHtml(getField('title'));
      const dek = escapeHtml(getField('dek'));
      const body = escapeHtml(getField('bodyMarkdown'))
        .replace(/\n{2,}/g, '</p><p>')
        .replace(/\n/g, '<br>');
      const image = getField('replacementImage') || getField('heroImage') || getField('generatedImage') || getField('sourceImage');
      const imageHtml = image ? `<img src="${escapeHtml(image)}" alt="${escapeHtml(getField('imageAlt') || title)}" loading="lazy">` : '';
      preview.innerHTML = `<article class="admin-preview-article">${imageHtml}<h3>${title || 'Untitled draft'}</h3><p>${dek}</p><p>${body}</p></article>`;
    };

    const showEditor = async () => {
      setStatus('Loading article...');
      const payload = await requestJson(`/api/admin/article?id=${encodeURIComponent(articleId)}`);
      fillForm(payload.article);
      if (loginPanel) loginPanel.hidden = true;
      if (editorPanel) editorPanel.hidden = false;
      setStatus(`Loaded from ${payload.sourceFile}.`, 'success');
    };

    const checkSession = async () => {
      try {
        const session = await requestJson('/api/admin/login');
        csrfToken = session.csrfToken || '';
        await showEditor();
      } catch {
        if (loginPanel) loginPanel.hidden = false;
        if (editorPanel) editorPanel.hidden = true;
        setStatus('Sign in to edit this article.');
      }
    };

    loginForm?.addEventListener('submit', async (event) => {
      event.preventDefault();
      const data = Object.fromEntries(new FormData(loginForm));
      try {
        setStatus('Signing in...');
        const session = await requestJson('/api/admin/login', {
          method: 'POST',
          body: JSON.stringify(data),
        });
        csrfToken = session.csrfToken || '';
        await showEditor();
      } catch (error) {
        setStatus(error.message, 'error');
      }
    });

    articleForm?.addEventListener('submit', async (event) => {
      event.preventDefault();
      const data = Object.fromEntries(new FormData(articleForm));
      data.id = articleId;
      data.action = actionInput?.value || 'save-draft';
      data.tags = String(data.tags || '')
        .split(',')
        .map((tag) => tag.trim())
        .filter(Boolean);

      try {
        setStatus(`Running ${data.action}...`);
        const payload = await requestJson('/api/admin/article', {
          method: 'POST',
          body: JSON.stringify(data),
        });
        fillForm(payload.article);
        const commit = payload.commitUrl ? ` Commit: ${payload.commitUrl}` : '';
        const audit = payload.auditEntry?.action ? ` Action: ${payload.auditEntry.action}.` : '';
        setStatus(`Saved. Vercel should redeploy after GitHub receives the commit.${audit}${commit}`, 'success');
      } catch (error) {
        setStatus(error.message, 'error');
      }
    });

    articleForm?.addEventListener('click', (event) => {
      const button = event.target.closest('[data-action]');
      if (!button) return;
      const action = button.getAttribute('data-action') || 'save-draft';
      if (actionInput) actionInput.value = action;
      if (action === 'preview') {
        event.preventDefault();
        renderPreviewFromForm();
        setStatus('Preview updated.', 'success');
      }
    });

    articleForm?.addEventListener('input', renderPreviewFromForm);

    logoutButton?.addEventListener('click', async () => {
      await requestJson('/api/admin/login', { method: 'DELETE' }).catch(() => {});
      csrfToken = '';
      if (loginPanel) loginPanel.hidden = false;
      if (editorPanel) editorPanel.hidden = true;
      setStatus('Signed out.');
    });

    checkSession();
  </script>
</Layout>
