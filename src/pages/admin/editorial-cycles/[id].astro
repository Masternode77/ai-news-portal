---
import Layout from '../../../layouts/Layout.astro';
import cycles from '../../../data/editorial-cycles.json';

export function getStaticPaths() {
  return (cycles || []).map((cycle) => ({ params: { id: cycle.cycle_id }, props: { cycle } }));
}

const { cycle } = Astro.props;
---
<Layout title={`${cycle.cycle_id} Admin`} noindex={true}>
  <main class="admin-shell">
    <header class="admin-header">
      <a class="admin-back" href="/admin/editorial-cycles/">Editorial cycles</a>
      <h1>{cycle.cycle_id}</h1>
      <p class="admin-deck">{cycle.status}</p>
    </header>
    <section class="admin-panel">
      <pre>{JSON.stringify(cycle, null, 2)}</pre>
    </section>
  </main>
</Layout>
