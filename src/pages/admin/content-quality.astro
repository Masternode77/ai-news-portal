---
import Layout from '../../layouts/Layout.astro';
import InternalQualityPanel from '../../components/InternalQualityPanel.astro';
import latestNews from '../../data/latest-news.json';
import archivedNews from '../../data/archived-news.json';
import { SITE } from '../../config/site';
import { buildAdminQualityModel } from '../../../scripts/lib/admin-quality-model.mjs';

const records = [...latestNews, ...archivedNews]
  .filter((article) => article?.id)
  .slice(0, 120)
  .map((article) => ({
    article,
    quality: buildAdminQualityModel(article),
  }));
---
<Layout
  title={`Content Quality | ${SITE.name}`}
  description="Private Compute Current content quality dashboard"
  canonicalPath="/admin/content-quality/"
  noindex={true}
>
  <main class="admin-shell">
    <header class="admin-header">
      <a class="back-link admin-back" href="/">Public site</a>
      <div>
        <p class="eyebrow">Admin Debug</p>
        <h1>Content quality</h1>
      </div>
      <p class="admin-deck">Internal QA metadata for scoring, extraction, routing, truncation, forbidden phrases, and NarrativeDNA. These labels are intentionally kept off public article cards.</p>
    </header>

    <section class="admin-panel">
      <div class="quality-list">
        {records.map(({ article, quality }) => (
          <article class="quality-list-item">
            <div>
              <p class="eyebrow">{quality.routing_decision}</p>
              <h2><a href={`/admin/content-quality/${article.id}/`}>{article.title}</a></h2>
              <p>{article.source} · {article.publishedAt ? new Date(article.publishedAt).toLocaleString('en-US') : 'Unknown date'}</p>
            </div>
            <InternalQualityPanel quality={quality} />
          </article>
        ))}
      </div>
    </section>
  </main>
</Layout>
