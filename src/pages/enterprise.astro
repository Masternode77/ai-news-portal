---
import Layout from '../layouts/Layout.astro';
import { SITE } from '../config/site';
import { ENTERPRISE_CAPABILITIES } from '../../scripts/lib/enterprise-leads.mjs';
---
<Layout
  title={`Enterprise | ${SITE.name}`}
  description="Compute Current Terminal for enterprise AI infrastructure intelligence."
  canonicalPath="/enterprise/"
>
  <main class="product-shell">
    <section class="product-hero">
      <p class="eyebrow">Compute Current Terminal</p>
      <h1>Enterprise intelligence for AI infrastructure teams.</h1>
      <p>
        Custom watchlists, dashboards, alerts, API/RSS access, monthly analyst calls, and custom research for teams tracking power, capacity, capital, silicon, and policy risk.
      </p>
      <a class="product-button" href="/enterprise/request-demo/" data-analytics-event="enterprise_cta_click">Request Enterprise Demo</a>
    </section>
    <section class="product-grid product-grid-three">
      {ENTERPRISE_CAPABILITIES.map((capability) => (
        <article class="product-card">
          <h2>{capability}</h2>
          <p>Enterprise-ready capability for custom AI infrastructure monitoring and decision support.</p>
        </article>
      ))}
    </section>
  </main>
</Layout>
