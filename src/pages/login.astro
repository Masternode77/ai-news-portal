---
import Layout from '../layouts/Layout.astro';
import { SITE } from '../config/site';
---
<Layout title={`Login | ${SITE.name}`} description="Login placeholder for Compute Current subscribers." canonicalPath="/login/">
  <main class="product-shell product-shell-narrow">
    <section class="product-hero">
      <p class="eyebrow">Subscriber Login</p>
      <h1>Subscriber access is being prepared.</h1>
      <p>
        Account authentication is not connected yet. Until checkout and identity are configured, Pro and Enterprise CTAs collect demand rather than blocking public content.
      </p>
      <a class="product-button" href="/pricing/">View pricing</a>
    </section>
  </main>
</Layout>
