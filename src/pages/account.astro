---
import Layout from '../layouts/Layout.astro';
import { SITE } from '../config/site';
---
<Layout title={`Account | ${SITE.name}`} description="Account placeholder for Compute Current subscribers." canonicalPath="/account/">
  <main class="product-shell product-shell-narrow">
    <section class="product-hero">
      <p class="eyebrow">Account</p>
      <h1>Your Compute Current account will manage saved topics, briefings, and team access.</h1>
      <p>
        This page is subscription-ready plumbing for Pro, Team, and Enterprise features. Authentication and billing integrations can attach here without changing the public editorial surface.
      </p>
      <a class="product-button" href="/subscribe/">Get the Daily Brief</a>
    </section>
  </main>
</Layout>
