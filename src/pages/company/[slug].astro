---
import Layout from '../../layouts/Layout.astro';
import LatestAnalysisFeed from '../../components/LatestAnalysisFeed.astro';
import PublicListingPage from '../../components/PublicListingPage.astro';
import taxonomyPages from '../../data/taxonomy-pages.json';
import { SITE } from '../../config/site';
import { buildHomepageFeed } from '../../../scripts/lib/homepage-feed-builder.mjs';

export function getStaticPaths() {
  return (taxonomyPages.companies || []).map((page) => ({ params: { slug: page.slug }, props: { page } }));
}

const { page } = Astro.props;
const feed = buildHomepageFeed(page.items || [], { limit: 50, minimumVisible: 0 });
---
<Layout title={`${page.name} | ${SITE.name}`} description={`Compute Current coverage involving ${page.name}.`} canonicalPath={`/company/${page.slug}/`}>
  <PublicListingPage
    eyebrow="Company coverage"
    title={page.name}
    lede={`Published AI infrastructure analysis and source-linked briefs involving ${page.name}.`}
    activePath={`/company/${page.slug}/`}
  >
    <LatestAnalysisFeed feed={feed} title={page.name} dek="" />
  </PublicListingPage>
</Layout>
