---
import Layout from '../layouts/Layout.astro';
import { SITE } from '../config/site';
const inquiryTypes = ['Subscribe', 'Advertise', 'Enterprise', 'Reports', 'Correction request', 'Partnership'];
---
<Layout title={`Contact | ${SITE.name}`} description="Contact Compute Current for subscriptions, advertising, enterprise, reports, corrections, and partnerships." canonicalPath="/contact/">
  <main class="product-shell product-shell-narrow">
    <section class="product-hero">
      <p class="eyebrow">Contact</p>
      <h1>Route your Compute Current inquiry.</h1>
      <p>Use this form for subscriptions, sponsorship, enterprise access, reports, correction requests, and partnerships.</p>
    </section>
    <form class="conversion-form lead-form-full" data-form-name="contact" data-analytics-submit="enterprise_cta_click">
      <div class="form-grid-two">
        <label><span>Name</span><input name="name" required /></label>
        <label><span>Email</span><input name="email" type="email" required /></label>
      </div>
      <label>
        <span>Inquiry type</span>
        <select name="inquiry_type">{inquiryTypes.map((type) => <option value={type}>{type}</option>)}</select>
      </label>
      <label><span>Message</span><textarea name="message" rows="5"></textarea></label>
      <button type="submit">Send inquiry</button>
      <p class="form-status" data-form-status></p>
    </form>
  </main>
</Layout>
