---
import Layout from '../../layouts/Layout.astro';
import LatestAnalysisFeed from '../../components/LatestAnalysisFeed.astro';
import PublicListingPage from '../../components/PublicListingPage.astro';
import taxonomyPages from '../../data/taxonomy-pages.json';
import { SITE } from '../../config/site';
import { buildTaxonomyListingFeed } from '../../../scripts/lib/taxonomy-page-builder.mjs';

export function getStaticPaths() {
  return (taxonomyPages.regions || []).map((page) => ({ params: { slug: page.slug }, props: { page } }));
}

const { page } = Astro.props;
const feed = buildTaxonomyListingFeed(page.items || []);
---
<Layout title={`${page.name} | ${SITE.name}`} description={`Compute Current regional coverage for ${page.name}.`} canonicalPath={`/region/${page.slug}/`}>
  <PublicListingPage
    eyebrow="Regional coverage"
    title={page.name}
    lede={`Published AI infrastructure analysis and source-linked briefs across ${page.name}.`}
    activePath={`/region/${page.slug}/`}
  >
    <LatestAnalysisFeed feed={feed} title={page.name} dek="" />
  </PublicListingPage>
</Layout>
