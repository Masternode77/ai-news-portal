---
import Layout from '../../layouts/Layout.astro';
import PublicSignalCard from '../../components/PublicSignalCard.astro';
import taxonomyPages from '../../data/taxonomy-pages.json';
import { SITE } from '../../config/site';
import { buildPublicPresentation } from '../../../scripts/lib/public-presentation.mjs';
import { routePublicLane } from '../../../scripts/lib/public-lane-router.mjs';

export function getStaticPaths() {
  return (taxonomyPages.regions || []).map((page) => ({ params: { slug: page.slug }, props: { page } }));
}

const { page } = Astro.props;
const pageRecord = page as any;
const pageTitle = pageRecord.name || pageRecord.title;
const items = (pageRecord.items || []).map((article) => ({
  publicSignal: buildPublicPresentation(article, { route: article.public_routing || routePublicLane(article) }),
}));
---
<Layout title={`${pageTitle} | ${SITE.name}`} description={`Compute Current regional coverage for ${pageTitle}.`} canonicalPath={`/region/${pageRecord.slug}/`}>
  <main class="policy-shell taxonomy-page">
    <a class="back-link" href="/">Latest board</a>
    <section class="policy-page">
      <p class="eyebrow">Region</p>
      <h1>{pageTitle}</h1>
      <p class="policy-lede">Regional signals for AI infrastructure operators, investors, and capacity teams.</p>
    </section>
    <div class="lane-grid taxonomy-grid">
      {items.map((item) => <PublicSignalCard signal={item.publicSignal} />)}
    </div>
  </main>
</Layout>
