---
import Layout from '../layouts/Layout.astro';
import ArticleCardImage from '../components/ArticleCardImage.astro';
import LatestAnalysisFeed from '../components/LatestAnalysisFeed.astro';
import PublicSiteHeader from '../components/PublicSiteHeader.astro';
import PublicSiteFooter from '../components/PublicSiteFooter.astro';
import latestNews from '../data/latest-news.json';
import archivedNews from '../data/archived-news.json';
import taxonomyPages from '../data/taxonomy-pages.json';
import { SITE } from '../config/site';
import { buildHomepageFeed } from '../../scripts/lib/homepage-feed-builder.mjs';
import { selectHomepageVisualLead } from '../../scripts/lib/homepage-visual-lead.mjs';

const homepageArticles = process.env.HOMEPAGE_FIXTURE === 'empty' ? [] : [...latestNews, ...archivedNews];
const feed = buildHomepageFeed(homepageArticles, { limit: 50, minimumVisible: 30 });
const dateFormatter = new Intl.DateTimeFormat('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
const leadSignal = selectHomepageVisualLead(feed);
const leadListExclusions = new Set([leadSignal?.id].filter(Boolean));
const latestFeed = {
  ...feed,
  items: leadListExclusions.size
    ? feed.items.filter((item) => !leadListExclusions.has(item.publicSignal?.id))
    : feed.items,
};
const leadHref = leadSignal?.view_detail || leadSignal?.read_source || '/archive/';
const leadDate = leadSignal?.date ? dateFormatter.format(new Date(leadSignal.date)) : 'Latest analysis';
const leadHeadline = leadSignal?.homepage_headline || leadSignal?.title;
const leadImage = leadSignal?.image || '/generated/fallbacks/ai-infrastructure.svg';
const leadImageAlt = leadSignal?.image_alt
  || (leadSignal?.title ? `${leadSignal.title} editorial visual` : 'Compute Current editorial visual');

const decisionLanes = [
  ['Power & grid', 'Interconnection, generation and energization timing', '/category/power-grid/'],
  ['Capacity', 'Campus delivery, leases and cloud commitments', '/category/data-centers/'],
  ['Silicon', 'Accelerator supply, packaging and systems', '/category/semiconductors/'],
  ['Cooling', 'Thermal design, water and rack density', '/category/cooling/'],
  ['Capital', 'Financing, capex and policy exposure', '/category/capital-markets/'],
];
const discoveryGroups = [
  {
    title: 'Coverage',
    links: (taxonomyPages.categories || []).slice(0, 7).map((item) => [item.title, `/category/${item.slug}/`]),
  },
  {
    title: 'Companies',
    links: (taxonomyPages.companies || []).slice(0, 7).map((item) => [item.name, `/company/${item.slug}/`]),
  },
  {
    title: 'Regions',
    links: (taxonomyPages.regions || [])
      .filter((item) => item.items?.length)
      .slice(0, 7)
      .map((item) => [item.name, `/region/${item.slug}/`]),
  },
];
---
<Layout
  title={SITE.name}
  description="Open AI infrastructure intelligence for power, data centers, chips, cloud capacity, cooling, and capital."
  canonicalPath="/"
>
  <div class="public-site public-home">
    <PublicSiteHeader activePath="/" />
    <main>
      <section class="public-lead" aria-labelledby="public-lead-title">
        <div class="public-lead-copy">
          <div class="public-lead-meta">
            <span>{leadSignal?.format_label || 'Latest analysis'}</span>
            {leadSignal?.category ? <span>{leadSignal.category}</span> : null}
            {leadSignal?.date ? <time datetime={leadSignal.date}>{leadDate}</time> : <span>{leadDate}</span>}
          </div>
          <h1 id="public-lead-title">
            {leadHeadline || 'AI infrastructure intelligence, grounded in public sources.'}
          </h1>
          <p>
            {leadSignal?.deck
              || 'Read source-linked analysis across power, capacity, silicon, cooling, policy and capital.'}
          </p>
          <div class="public-lead-actions">
            <a class="public-primary-action" href={leadHref}>
              {leadSignal?.view_detail ? 'Read the analysis' : 'Read the source brief'}
            </a>
            <a href="/archive/">Browse all coverage</a>
          </div>
        </div>
        <ArticleCardImage
          image={leadImage}
          imageAlt={leadImageAlt}
          href={leadHref}
          className="public-lead-image"
          linkClassName="public-lead-visual"
          priority={true}
          width={1536}
          height={864}
          ariaLabel={leadSignal?.title || 'Read the latest analysis'}
          provenanceLabel={leadSignal?.image_provenance_label || ''}
          provenanceKind={leadSignal?.image_provenance_kind || ''}
        />
      </section>

      <section class="public-decision-index" aria-label="Coverage by infrastructure decision">
        {decisionLanes.map(([title, description, href]) => (
          <a href={href}>
            <span>{title}</span>
            <strong>{description}</strong>
          </a>
        ))}
      </section>

      <LatestAnalysisFeed
        feed={latestFeed}
        title="Latest intelligence"
        eyebrow="Current edition"
        dek="Source-linked analysis and briefs across the systems, suppliers and capital behind AI deployment."
      />

      <section class="public-discovery" aria-labelledby="public-discovery-title">
        <header>
          <p class="eyebrow">Explore the archive</p>
          <h2 id="public-discovery-title">Follow the infrastructure layer that matters to your decision.</h2>
          <a href="/search/">Search all public coverage</a>
        </header>
        <div>
          {discoveryGroups.map((group) => (
            <section>
              <h3>{group.title}</h3>
              <nav aria-label={group.title}>
                {group.links.map(([label, href]) => <a href={href}>{label}</a>)}
              </nav>
            </section>
          ))}
        </div>
      </section>
    </main>
    <PublicSiteFooter />
  </div>
</Layout>
