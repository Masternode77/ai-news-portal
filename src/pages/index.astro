---
import Layout from '../layouts/Layout.astro';
import newsData from '../data/latest-news.json';

const boardTitle = 'AI / Data Center Signal Board';

const formatTimeAgo = (iso) => {
  const ms = Date.now() - new Date(iso).getTime();
  const mins = Math.max(1, Math.floor(ms / 60000));
  if (mins < 60) return `${mins}m ago`;
  const hours = Math.floor(mins / 60);
  if (hours < 24) return `${hours}h ago`;
  const days = Math.floor(hours / 24);
  return `${days}d ago`;
};

const cards = (newsData || []).map((item, idx) => ({
  ...item,
  summary: item.summary || item.snippet || '',
  insight:
    item.insight ||
    'Expert lens: Capacity, power, network topology, and silicon procurement should be planned as one system.',
  generatedImage: item.generatedImage || '/generated/default.svg',
  timeAgo: formatTimeAgo(item.publishedAt),
  isHero: idx === 0,
}));

const hero = cards[0];
const rest = cards.slice(1);
const categories = [...new Set(cards.map((item) => item.category).filter(Boolean))];
const stats = [
  { label: 'Tracked / run', value: '30' },
  { label: 'Curated / day', value: '6' },
  { label: 'Published / run', value: '2' },
];
---
<Layout title={boardTitle}>
  <main class="page-shell">
    <div class="ambient ambient-a"></div>
    <div class="ambient ambient-b"></div>
    <div class="ambient-grid"></div>

    <section class="topbar panel panel-herohead">
      <div class="topbar-copy">
        <p class="eyebrow">Curated AI / Data Center Intelligence</p>
        <h1>{boardTitle}</h1>
        <p class="deck">
          Global tech, AI infrastructure, data center, semiconductor, and power-market signals curated on an
          8-hour publishing cycle.
        </p>

        <div class="chip-row">
          {categories.length > 0 ? (
            categories.slice(0, 5).map((category) => <span class="chip">{category}</span>)
          ) : (
            <>
              <span class="chip">Hyperscalers &amp; Cloud</span>
              <span class="chip">AI Infrastructure</span>
              <span class="chip">Power / Grid / Energy</span>
            </>
          )}
        </div>
      </div>

      <div class="stat-grid">
        {stats.map((stat) => (
          <div class="stat-card">
            <span class="stat-label">{stat.label}</span>
            <strong>{stat.value}</strong>
          </div>
        ))}
        <div class="stat-card stat-card-wide">
          <span class="stat-label">Updated</span>
          <strong>
            {new Date().toLocaleString('en-US', {
              month: 'short',
              day: 'numeric',
              hour: '2-digit',
              minute: '2-digit',
            })}
          </strong>
        </div>
      </div>
    </section>

    {hero ? (
      <article class="hero-card panel">
        <div class="hero-media">
          <img src={hero.generatedImage} alt={hero.title} loading="eager" />
          <div class="media-sheen"></div>
        </div>

        <div class="hero-content">
          <div class="meta-strip">
            <span class="category-badge">{hero.category || 'Infrastructure'}</span>
            <span class="source-pill">{hero.source}</span>
            <span class="region-pill">{hero.region || 'Global'}</span>
            <time>{hero.timeAgo}</time>
          </div>

          <h2>
            <a href={hero.url} target="_blank" rel="noreferrer">
              {hero.title}
            </a>
          </h2>

          <p class="summary summary-hero">{hero.summary}</p>

          <div class="insight-block">
            <span>Expert lens</span>
            <p>{hero.insight}</p>
          </div>

          {hero.tags?.length ? (
            <div class="tag-row">
              {hero.tags.slice(0, 6).map((tag) => (
                <span class="tag-pill">#{tag}</span>
              ))}
            </div>
          ) : null}

          <div class="hero-actions">
            <a class="link-button" href={hero.url} target="_blank" rel="noreferrer">
              Read original
            </a>
          </div>
        </div>
      </article>
    ) : (
      <section class="empty-board panel">
        <h2>Pipeline ready</h2>
        <p>
          The board will populate after the next scheduled curation run. Once the workflow executes, the latest
          two stories for the current slot will appear here automatically.
        </p>
      </section>
    )}

    <section class="feed-header">
      <div>
        <p class="eyebrow">Latest published cards</p>
        <h3>Signal board</h3>
      </div>
      <p class="feed-copy">
        Each card keeps the original source title, a tight 1–2 line summary, and an operator/investor lens for
        faster triage.
      </p>
    </section>

    <section class="masonry-board">
      {rest.map((item) => (
        <article class="news-card panel">
          <div class="card-media">
            <img src={item.generatedImage} alt={item.title} loading="lazy" />
            <div class="card-media-overlay"></div>
          </div>

          <div class="card-content">
            <div class="meta-row">
              <span class="category-badge">{item.category || 'Infrastructure'}</span>
              <time>{item.timeAgo}</time>
            </div>

            <div class="meta-row meta-row-secondary">
              <span class="source-pill">{item.source}</span>
              <span class="region-pill">{item.region || 'Global'}</span>
            </div>

            <h4>
              <a href={item.url} target="_blank" rel="noreferrer">
                {item.title}
              </a>
            </h4>

            <p class="summary">{item.summary}</p>
            <p class="insight">{item.insight}</p>

            {item.tags?.length ? (
              <div class="tag-row tag-row-compact">
                {item.tags.slice(0, 4).map((tag) => (
                  <span class="tag-pill">#{tag}</span>
                ))}
              </div>
            ) : null}
          </div>
        </article>
      ))}
    </section>
  </main>
</Layout>
