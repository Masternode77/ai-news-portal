---
import Layout from '../layouts/Layout.astro';
import latestNews from '../data/latest-news.json';
import archivedNews from '../data/archived-news.json';
import searchIndex from '../data/search-index.json';

const boardTitle = 'AI / Data Center\nSignal Board';

const formatTimeAgo = (iso) => {
  const ms = Date.now() - new Date(iso).getTime();
  const mins = Math.max(1, Math.floor(ms / 60000));
  if (mins < 60) return `${mins}m ago`;
  const hours = Math.floor(mins / 60);
  if (hours < 24) return `${hours}h ago`;
  const days = Math.floor(hours / 24);
  return `${days}d ago`;
};

const getLensTeaser = (item) => item.expertLensShort || item.expertLens || item.expertLensFull?.thesis || '';

const latest = (latestNews || []).map((item, idx) => ({
  ...item,
  summary: item.summary || item.snippet || '',
  expertLensTeaser: getLensTeaser(item),
  generatedImage: item.generatedImage || '/generated/default.svg',
  detailHref: `/news/${item.id}/`,
  sourceUrl: item.sourceUrl || item.url,
  timeAgo: formatTimeAgo(item.publishedAt),
  isHero: idx === 0,
  hasExpertLens: Boolean(getLensTeaser(item)),
}));

const archiveCount = archivedNews.length;
const hero = latest[0];
const spotlight = latest.slice(1, 3);
const feed = latest.slice(3);
const categories = [...new Set(latest.map((item) => item.category).filter(Boolean))];
const searchPayload = (searchIndex || []).slice(0, 400).map((item) => ({
  id: item.id,
  title: item.title,
  source: item.source,
  category: item.category,
  region: item.region,
  summary: item.summary || item.snippet || '',
  expertLensTeaser: getLensTeaser(item),
  searchText: item.searchText || [
    item.title,
    item.source,
    item.category,
    item.region,
    item.summary,
    item.expertLensShort,
    item.expertLens,
    item.expertLensFull?.thesis,
    item.expertLensFull?.whyThisMatters,
  ].filter(Boolean).join(' '),
  publishedAt: item.publishedAt,
  href: `/news/${item.id}/`,
  sourceUrl: item.sourceUrl || item.url,
}));
const stats = [
  { label: 'Live Surface', value: `${latest.length}` },
  { label: 'Archived', value: `${archiveCount}` },
  { label: 'Refresh', value: '8h' },
];
---
<Layout title={boardTitle} description="An AI and data center intelligence board with archive search, refreshed every 8 hours.">
  <main class="page-shell">
    <div class="ambient ambient-a"></div>
    <div class="ambient ambient-b"></div>
    <div class="ambient-grid"></div>

    <section class="topbar panel panel-herohead">
      <div class="topbar-copy">
        <p class="eyebrow">Curated AI / Data Center Intelligence</p>
        <h1 style="white-space: pre-line;">{boardTitle}</h1>
        <p class="deck">
          Fresh stories update the live surface every 8 hours, while older coverage moves into the archive and remains searchable.
        </p>

        <div class="chip-row">
          {categories.length > 0 ? (
            categories.slice(0, 5).map((category) => <span class="chip">{category}</span>)
          ) : null}
        </div>
      </div>

      <div class="stat-grid">
        {stats.map((stat) => (
          <div class="stat-card">
            <span class="stat-label">{stat.label}</span>
            <strong>{stat.value}</strong>
          </div>
        ))}
        <div class="stat-card stat-card-wide">
          <span class="stat-label">Updated</span>
          <strong>
            {new Date().toLocaleString('en-US', {
              month: 'short',
              day: 'numeric',
              hour: 'numeric',
              minute: '2-digit',
            })}
          </strong>
        </div>
      </div>
    </section>

    <section class="search-shell panel">
      <div class="search-copy">
        <p class="eyebrow">Unified Search</p>
        <h2>Search live coverage and the archive at once</h2>
        <p>Filter instantly by title, source, category, region, or summary.</p>
      </div>
      <label class="search-input-wrap">
        <span class="sr-only">Search news archive</span>
        <input id="news-search" class="search-input" type="search" placeholder="e.g. nvidia, cooling, korea, power" />
      </label>
      <div id="search-meta" class="search-meta">Loaded {searchPayload.length} indexed items</div>
      <div id="search-results" class="search-results"></div>
    </section>

    {hero ? (
      <section class="hero-grid">
        <article class="hero-card panel">
          <div class="hero-media">
            <img src={hero.generatedImage} alt={hero.title} loading="eager" />
            <div class="media-sheen"></div>
          </div>

          <div class="hero-content">
            <div class="meta-strip">
              <span class="category-badge">{hero.category || 'Infrastructure'}</span>
              <span class="source-pill">{hero.source}</span>
              <span class="region-pill">{hero.region || 'Global'}</span>
              <time>{hero.timeAgo}</time>
            </div>

            <h2>
              <a href={hero.detailHref}>{hero.title}</a>
            </h2>

            <p class="summary summary-hero">{hero.summary}</p>

            {hero.hasExpertLens ? (
              <section class="insight-block">
                <span>Expert Lens</span>
                <p>{hero.expertLensTeaser}</p>
              </section>
            ) : null}

            {hero.tags?.length ? (
              <div class="tag-row">
                {hero.tags.slice(0, 6).map((tag) => (
                  <span class="tag-pill">#{tag}</span>
                ))}
              </div>
            ) : null}

            <div class="hero-actions">
              <a class="detail-button" href={hero.detailHref}>
                View detail
              </a>
              <a class="source-cta" href={hero.sourceUrl} target="_blank" rel="noreferrer">
                Read original source
              </a>
            </div>
          </div>
        </article>

        <aside class="spotlight-stack">
          {spotlight.map((item) => (
            <article class="spotlight-card panel">
              <div class="spotlight-meta">
                <span class="category-badge">{item.category}</span>
                <time>{item.timeAgo}</time>
              </div>
              <h3>
                <a href={item.detailHref}>{item.title}</a>
              </h3>
              <p>{item.summary}</p>
              {item.hasExpertLens ? <p class="spotlight-lens">{item.expertLensTeaser}</p> : null}
              <div class="card-footer">
                <a class="detail-link" href={item.detailHref}>
                  Detail
                </a>
                <a class="source-cta" href={item.sourceUrl} target="_blank" rel="noreferrer">
                  Source
                </a>
              </div>
            </article>
          ))}
        </aside>
      </section>
    ) : (
      <section class="empty-board panel">
        <h2>Pipeline ready</h2>
        <p>The board will fill automatically after the next 8-hour pipeline run.</p>
      </section>
    )}

    <section class="feed-header">
      <div>
        <p class="eyebrow">Latest published cards</p>
        <h3>Signal board</h3>
      </div>
      
    </section>

    <section class="masonry-board">
      {feed.map((item) => (
        <article class="news-card panel">
          <div class="card-media">
            <img src={item.generatedImage} alt={item.title} loading="lazy" />
            <div class="card-media-overlay"></div>
          </div>

          <div class="card-content">
            <div class="meta-row">
              <span class="category-badge">{item.category || 'Infrastructure'}</span>
              <time>{item.timeAgo}</time>
            </div>

            <div class="meta-row meta-row-secondary">
              <span class="source-pill">{item.source}</span>
              <span class="region-pill">{item.region || 'Global'}</span>
            </div>

            <h4>
              <a href={item.detailHref}>{item.title}</a>
            </h4>

            <p class="summary">{item.summary}</p>

            {item.tags?.length ? (
              <div class="tag-row tag-row-compact">
                {item.tags.slice(0, 4).map((tag) => (
                  <span class="tag-pill">#{tag}</span>
                ))}
              </div>
            ) : null}

            <div class="card-footer">
              <a class="detail-link" href={item.detailHref}>
                View detail
              </a>
              <a class="source-cta" href={item.sourceUrl} target="_blank" rel="noreferrer">
                Read source
              </a>
            </div>
          </div>
        </article>
      ))}
    </section>
  </main>

  <script type="application/json" id="search-index-data" set:html={JSON.stringify(searchPayload)}></script>
  <script>
    const input = document.getElementById('news-search');
    const results = document.getElementById('search-results');
    const meta = document.getElementById('search-meta');
    const payload = JSON.parse(document.getElementById('search-index-data')?.textContent || '[]');

    const formatDate = (value) =>
      new Date(value).toLocaleDateString('en-US', {
        month: 'short',
        day: 'numeric',
      });

    const render = (items, query = '') => {
      if (!results || !meta) return;

      if (!query.trim()) {
        results.innerHTML = '';
        meta.textContent = `Loaded ${payload.length} indexed items`;
        return;
      }

      if (!items.length) {
        results.innerHTML = '<p class="search-empty">No matching results found.</p>';
        meta.textContent = `0 results for "${query}"`;
        return;
      }

      meta.textContent = `${items.length} results for "${query}"`;
      results.innerHTML = items
        .slice(0, 12)
        .map(
          (item) => `
            <article class="search-result-card">
              <div>
                <div class="search-result-meta">${item.source} · ${item.category || 'Infrastructure'} · ${formatDate(item.publishedAt)}</div>
                <h3><a href="${item.href}">${item.title}</a></h3>
                <p>${item.expertLensTeaser || item.summary || ''}</p>
              </div>
              <a class="source-cta" href="${item.sourceUrl}" target="_blank" rel="noreferrer">Source</a>
            </article>
          `
        )
        .join('');
    };

    input?.addEventListener('input', (event) => {
      const query = event.target.value.toLowerCase().trim();
      const matches = payload.filter((item) =>
        `${item.searchText || ''} ${item.title} ${item.source} ${item.category || ''} ${item.region || ''} ${item.summary || ''}`
          .toLowerCase()
          .includes(query)
      );
      render(matches, query);
    });
  </script>
</Layout>
