---
import Layout from '../layouts/Layout.astro';
import latestNews from '../data/latest-news.json';
import archivedNews from '../data/archived-news.json';
import searchIndex from '../data/search-index.json';
import { SITE } from '../config/site';
import { cleanEditorialText, displayHeadline } from '../lib/editorial-display.js';
import { shouldNoindexArticle } from '../lib/seo-safeguards.js';
import { taxonomyDisplay } from '../lib/taxonomy-display.js';

const boardTitle = SITE.name;

const formatTimeAgo = (iso: string) => {
  const ms = Date.now() - new Date(iso).getTime();
  const mins = Math.max(1, Math.floor(ms / 60000));
  if (mins < 60) return `${mins}m ago`;
  const hours = Math.floor(mins / 60);
  if (hours < 24) return `${hours}h ago`;
  const days = Math.floor(hours / 24);
  return `${days}d ago`;
};

const getLensTeaser = (item: any) => item.expertLensShort || item.expertLens || item.expertLensFull?.thesis || '';

const homepageEligibleNews = (latestNews || []).filter((item: any) =>
  item.homepagePublished !== false
  && item.archiveOnly !== true
  && item.infrastructure_relevance_action !== 'archive_only'
);

const latest = homepageEligibleNews.map((item: any, idx) => {
  const sourceUrl = item.sourceUrl || item.url;
  const hasArticlePage = item['articlePagePublished'] !== false && !shouldNoindexArticle(item);
  return {
    ...item,
    taxonomy: taxonomyDisplay(item),
    hasArticlePage,
    title: displayHeadline(item),
    summary: cleanEditorialText(item.summary || item.snippet || ''),
    expertLensTeaser: cleanEditorialText(getLensTeaser(item)),
    displayImage: item.sourceImage || item.generatedImage || '/generated/default.svg',
    detailHref: hasArticlePage ? `/news/${item.id}/` : sourceUrl,
    sourceUrl,
    timeAgo: formatTimeAgo(item.publishedAt),
    isHero: idx === 0,
    hasExpertLens: Boolean(getLensTeaser(item)),
    relevanceScore: Number.isFinite(Number(item.infrastructure_relevance_score)) ? Number(item.infrastructure_relevance_score) : null,
    extractionQuality: Number.isFinite(Number(item.extraction_quality_score)) ? Number(item.extraction_quality_score) : null,
    blueprintId: item.article_blueprint || item.articleBlueprint?.id || item.expertLensFull?.blueprintId || null,
  };
});

const archiveCount = archivedNews.length;
const intelligenceNav = [
  "Today's Constraint",
  'Operator Alerts',
  'Investor Signals',
  'Stack Shifts',
  'Policy/Risk Watch',
  'Technical Bottlenecks',
];
const formatMetric = (value: number | null) => typeof value === 'number' && Number.isFinite(value) ? value.toFixed(2) : 'n/a';
const formatBlueprint = (value: string | null) => value
  ? value.split('-').map((part) => part.charAt(0).toUpperCase() + part.slice(1)).join(' ')
  : 'Legacy';
const topConstraint = [...latest].sort((a: any, b: any) => {
  const aScore = (a.taxonomy.urgency || 0) * 0.58 + (a.relevanceScore || 0) * 0.42;
  const bScore = (b.taxonomy.urgency || 0) * 0.58 + (b.relevanceScore || 0) * 0.42;
  return bScore - aScore;
})[0];
const usedIds = new Set(topConstraint ? [topConstraint.id] : []);
const includesAny = (values: string[], terms: string[]) => values.some((value) => terms.some((term) => value.includes(term)));
const articleSignals = (item: any) => [
  item.title,
  item.summary,
  item.expertLensTeaser,
  item.taxonomy.primary,
  item.taxonomy.secondary,
  item.taxonomy.layer,
  item.taxonomy.articleType,
  item.expert_insight?.bottleneck_type,
  ...(item.taxonomy.stakeholders || []),
  ...(item.tags || []),
].filter(Boolean).join(' ').toLowerCase();
const sectionDefinitions = [
  {
    key: 'operator-alerts',
    title: 'Operator Alerts',
    deck: 'Capacity, uptime, procurement, and site execution items that change operating plans.',
    match: (item: any) => includesAny([articleSignals(item)], ['operator', 'developer', 'facility', 'capacity expansion', 'operations', 'power', 'cooling', 'cloud platform']),
  },
  {
    key: 'investor-signals',
    title: 'Investor Signals',
    deck: 'Capital formation, contract quality, pricing power, and exposure signals for infrastructure investors.',
    match: (item: any) => includesAny([articleSignals(item)], ['investor', 'capital', 'financing', 'funding', 'debt', 'm&a', 'acquisition', 'valuation']),
  },
  {
    key: 'stack-shifts',
    title: 'Stack Shifts',
    deck: 'Changes in cloud, silicon, network, platform, and workload architecture that alter the AI infrastructure stack.',
    match: (item: any) => includesAny([articleSignals(item)], ['compute', 'silicon', 'semiconductor', 'cloud', 'network', 'storage', 'platform', 'gpu', 'chip']),
  },
  {
    key: 'policy-risk-watch',
    title: 'Policy/Risk Watch',
    deck: 'Permitting, grid cost allocation, regulatory, siting, and regional risk items worth tracking.',
    match: (item: any) => includesAny([articleSignals(item)], ['policy', 'permit', 'regulation', 'risk', 'grid', 'utility', 'approval', 'siting', 'ratepayer']),
  },
  {
    key: 'technical-bottlenecks',
    title: 'Technical Bottlenecks',
    deck: 'Physical and systems constraints across power, cooling, networking, memory, facility design, and deployment readiness.',
    match: (item: any) => includesAny([articleSignals(item)], ['bottleneck', 'cooling', 'thermal', 'power', 'interconnection', 'network', 'hbm', 'memory', 'backup', 'disaster recovery']),
  },
];
const pickSectionItems = (definition: any) => {
  const matched = latest
    .filter((item: any) => !usedIds.has(item.id) && definition.match(item))
    .sort((a: any, b: any) => ((b.relevanceScore || 0) + (b.taxonomy.urgency || 0)) - ((a.relevanceScore || 0) + (a.taxonomy.urgency || 0)));
  const fallback = latest.filter((item: any) => !usedIds.has(item.id));
  const picked = [...matched, ...fallback].filter((item, index, list) => list.findIndex((candidate) => candidate.id === item.id) === index).slice(0, 4);
  picked.forEach((item) => usedIds.add(item.id));
  return picked;
};
const intelligenceSections = sectionDefinitions.map((definition) => ({
  ...definition,
  items: pickSectionItems(definition),
}));
const searchPayload = (searchIndex || []).slice(0, 400).map((item: any) => ({
  id: item.id,
  title: displayHeadline(item),
  source: item.source,
  category: item.primary_category || item.category,
  primary_category: item.primary_category || item.category,
  secondary_category: item.secondary_category,
  infrastructure_layer: item.infrastructure_layer,
  affected_stakeholders: item.affected_stakeholders || [],
  article_type: item.article_type,
  region: item.region,
  urgency_score: item.urgency_score,
  summary: cleanEditorialText(item.summary || item.snippet || ''),
  expertLensTeaser: cleanEditorialText(getLensTeaser(item)),
  searchText: item.searchText || [
    item.title,
    item.source,
    item.primary_category,
    item.secondary_category,
    item.infrastructure_layer,
    item.article_type,
    ...(item.affected_stakeholders || []),
    item.category,
    item.region,
    item.summary,
    item.expertLensShort,
    item.expertLens,
    item.expertLensFull?.thesis,
    item.expertLensFull?.whyThisMatters,
  ].filter(Boolean).join(' '),
  publishedAt: item.publishedAt,
  href: item['articlePagePublished'] === false || shouldNoindexArticle(item) ? item.sourceUrl || item.url : `/news/${item.id}/`,
  sourceUrl: item.sourceUrl || item.url,
}));
const stats = [
  { label: 'Live Signals', value: `${latest.length}` },
  { label: 'Archived', value: `${archiveCount}` },
  { label: 'IA Lanes', value: '6' },
  { label: 'Refresh', value: '8h' },
];
---
<Layout title={boardTitle} description={SITE.description} canonicalPath="/">
  <main class="page-shell">
    <div class="ambient ambient-a"></div>
    <div class="ambient ambient-b"></div>
    <div class="ambient-grid"></div>

    <header class="publication-header">
      <div class="edition-line">
        <span>AI Infrastructure Intelligence</span>
        <time>
          {new Date().toLocaleString('en-US', {
            month: 'short',
            day: 'numeric',
            hour: 'numeric',
            minute: '2-digit',
          })}
        </time>
      </div>

      <div class="masthead-row">
        <h1 aria-label={boardTitle}>
          <span>Compute</span>
          <span>Current</span>
        </h1>
        <p>
          {SITE.description}
        </p>
      </div>

      <div class="nav-strip">
        {intelligenceNav.map((item) => <span>{item}</span>)}
      </div>
    </header>

    <section class="live-brief">
      <div class="brief-kicker">Live Brief</div>
      <div class="brief-track">
        {stats.map((stat) => (
          <span><strong>{stat.value}</strong> {stat.label}</span>
        ))}
        <span><strong>{searchPayload.length}</strong> Indexed archive</span>
      </div>
    </section>

    {topConstraint ? (
      <section class="constraint-board">
        <article class="constraint-lead">
          <div class="constraint-label">
            <p class="eyebrow">Today's Constraint</p>
            <span>{topConstraint.taxonomy.layer}</span>
            <a class="constraint-media" href={topConstraint.detailHref} aria-label={topConstraint.title}>
              <img src={topConstraint.displayImage} alt={topConstraint.title} loading="eager" />
            </a>
          </div>
          <div class="constraint-copy">
            <div class="story-meta">
              <span>{topConstraint.source}</span>
              <span>{topConstraint.taxonomy.primary}</span>
              <span>{topConstraint.taxonomy.region}</span>
              <time>{topConstraint.timeAgo}</time>
            </div>
            <h2>
              <a href={topConstraint.detailHref}>{topConstraint.title}</a>
            </h2>
            <p>{topConstraint.expertLensTeaser || topConstraint.summary}</p>
          </div>
          <div class="metric-grid">
            <div><span>Infrastructure Layer</span><strong>{topConstraint.taxonomy.layer}</strong></div>
            <div><span>Affected Stakeholder</span><strong>{topConstraint.taxonomy.stakeholders[0] || 'Capacity teams'}</strong></div>
            <div><span>Relevance Score</span><strong>{formatMetric(topConstraint.relevanceScore)}</strong></div>
            <div><span>Urgency Score</span><strong>{formatMetric(topConstraint.taxonomy.urgency)}</strong></div>
            <div><span>Article Blueprint</span><strong>{formatBlueprint(topConstraint.blueprintId)}</strong></div>
            <div><span>Extraction Quality</span><strong>{formatMetric(topConstraint.extractionQuality)}</strong></div>
          </div>
        </article>

        <section class="intelligence-lanes" aria-label="Compute Current intelligence lanes">
          {intelligenceSections.map((section) => (
            <section class="intelligence-section">
              <div class="lane-heading">
                <div>
                  <p class="eyebrow">{section.title}</p>
                  <h2>{section.title}</h2>
                </div>
                <p>{section.deck}</p>
              </div>
              <div class="lane-grid">
                {section.items.map((item: any) => (
                  <article class="intel-card">
                    <div class="story-meta">
                      <span>{item.source}</span>
                      <span>{item.taxonomy.primary}</span>
                      <time>{item.timeAgo}</time>
                    </div>
                    <h3>
                      <a href={item.detailHref}>{item.title}</a>
                    </h3>
                    <p>{item.expertLensTeaser || item.summary}</p>
                    <div class="signal-metrics">
                      <div><span>Infrastructure Layer</span><strong>{item.taxonomy.layer}</strong></div>
                      <div><span>Affected Stakeholder</span><strong>{item.taxonomy.stakeholders[0] || 'Capacity teams'}</strong></div>
                      <div><span>Relevance Score</span><strong>{formatMetric(item.relevanceScore)}</strong></div>
                      <div><span>Urgency Score</span><strong>{formatMetric(item.taxonomy.urgency)}</strong></div>
                      <div><span>Article Blueprint</span><strong>{formatBlueprint(item.blueprintId)}</strong></div>
                      <div><span>Extraction Quality</span><strong>{formatMetric(item.extractionQuality)}</strong></div>
                    </div>
                    <div class="card-footer">
                      <a class="detail-link" href={item.detailHref}>View detail</a>
                      <a class="source-cta" href={item.sourceUrl} target="_blank" rel="noreferrer">Read source</a>
                    </div>
                  </article>
                ))}
              </div>
            </section>
          ))}
        </section>
      </section>
    ) : (
      <section class="empty-board panel">
        <h2>Pipeline ready</h2>
        <p>The board will fill automatically after the next 8-hour pipeline run.</p>
      </section>
    )}

    <section class="search-shell">
      <div class="search-copy">
        <p class="eyebrow">Archive Search</p>
        <h2>Search live and archived coverage</h2>
      </div>
      <label class="search-input-wrap">
        <span class="sr-only">Search news archive</span>
        <input id="news-search" class="search-input" type="search" placeholder="Search topics, companies, regions, power, cooling, chips..." />
      </label>
      <div id="search-meta" class="search-meta">Loaded {searchPayload.length} indexed items</div>
      <div id="search-results" class="search-results"></div>
    </section>

    <footer class="transparency-footer" aria-label="Editorial transparency">
      <div>
        <p class="eyebrow">Transparency</p>
        <p>
          AI-assisted infrastructure intelligence with source attribution, extraction QA, relevance gates, and noindex safeguards for low-quality generated pages.
        </p>
      </div>
      <nav class="policy-link-row" aria-label="Transparency pages">
        <a href="/about/">About</a>
        <a href="/editorial-policy/">Editorial Policy</a>
        <a href="/methodology/">Methodology</a>
        <a href="/ai-disclosure/">AI-assisted Disclosure</a>
      </nav>
    </footer>

  </main>

  <script is:inline type="application/json" id="search-index-data" set:html={JSON.stringify(searchPayload)}></script>
  <script>
    const input = document.getElementById('news-search');
    const results = document.getElementById('search-results');
    const meta = document.getElementById('search-meta');
    const payload = JSON.parse(document.getElementById('search-index-data')?.textContent || '[]');

    const formatDate = (value) =>
      new Date(value).toLocaleDateString('en-US', {
        month: 'short',
        day: 'numeric',
      });

    const render = (items, query = '') => {
      if (!results || !meta) return;

      if (!query.trim()) {
        results.innerHTML = '';
        meta.textContent = `Loaded ${payload.length} indexed items`;
        return;
      }

      if (!items.length) {
        results.innerHTML = '<p class="search-empty">No matching results found.</p>';
        meta.textContent = `0 results for "${query}"`;
        return;
      }

      meta.textContent = `${items.length} results for "${query}"`;
      results.innerHTML = items
        .slice(0, 12)
        .map(
          (item) => `
            <article class="search-result-card">
              <div>
                <div class="search-result-meta">${item.source} · ${item.primary_category || item.category || 'Infrastructure'} · ${item.infrastructure_layer || 'Layer n/a'} · ${formatDate(item.publishedAt)}</div>
                <h3><a href="${item.href}">${item.title}</a></h3>
                <p>${item.expertLensTeaser || item.summary || ''}</p>
              </div>
              <a class="source-cta" href="${item.sourceUrl}" target="_blank" rel="noreferrer">Source</a>
            </article>
          `
        )
        .join('');
    };

    input?.addEventListener('input', (event) => {
      const target = event.target;
      if (!(target instanceof HTMLInputElement)) return;
      const query = target.value.toLowerCase().trim();
      const matches = payload.filter((item) =>
        `${item.searchText || ''} ${item.title} ${item.source} ${item.primary_category || item.category || ''} ${item.secondary_category || ''} ${item.infrastructure_layer || ''} ${item.article_type || ''} ${(item.affected_stakeholders || []).join(' ')} ${item.region || ''} ${item.summary || ''}`
          .toLowerCase()
          .includes(query)
      );
      render(matches, query);
    });
  </script>
</Layout>
