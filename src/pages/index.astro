---
import Layout from '../layouts/Layout.astro';
import EditorialCycleStatus from '../components/EditorialCycleStatus.astro';
import FeaturedCycleAnalysis from '../components/FeaturedCycleAnalysis.astro';
import ActiveWatchlist from '../components/ActiveWatchlist.astro';
import RecentAnalysisArchive from '../components/RecentAnalysisArchive.astro';
import latestNews from '../data/latest-news.json';
import archivedNews from '../data/archived-news.json';
import editorialCycles from '../data/editorial-cycles.json';
import signalClusters from '../data/signal-clusters.json';
import sourceHealth from '../data/source-health.json';
import { SITE } from '../config/site';
import { buildHomepageEditorialModel } from '../../scripts/lib/homepage-editorial-model.mjs';

const boardTitle = SITE.name;
const model = buildHomepageEditorialModel({
  latest: latestNews,
  archived: archivedNews,
  cycles: editorialCycles,
  clusters: signalClusters,
  sourceHealth,
});

const navLinks = [
  ['Power & Grid', '/category/power-grid/'],
  ['Data Centers', '/category/data-centers/'],
  ['Cloud Capacity', '/category/cloud-capacity/'],
  ['Semiconductors', '/category/semiconductors/'],
  ['Cooling', '/category/cooling/'],
  ['Capital Markets', '/category/capital-markets/'],
  ['Regulation', '/category/regulation/'],
  ['Archive', '/archive/'],
];

const stats = [
  { label: 'Active Signals', value: model.stats.activeSignals },
  { label: 'Sources Monitored', value: model.stats.sourcesMonitored || 'configured' },
  { label: 'Pipeline', value: 'runs every 8h' },
  { label: 'Published Analyses Indexed', value: model.stats.publishedAnalysesIndexed },
];
---
<Layout title={boardTitle} description={SITE.description} canonicalPath="/">
  <main class="page-shell autonomous-home">
    <div class="ambient ambient-a"></div>
    <div class="ambient ambient-b"></div>
    <div class="ambient-grid"></div>

    <header class="publication-header">
      <div class="edition-line">
        <span>AI Infrastructure Intelligence</span>
        <time>
          {new Date().toLocaleString('en-US', {
            month: 'short',
            day: 'numeric',
            hour: 'numeric',
            minute: '2-digit',
          })}
        </time>
      </div>

      <div class="masthead-row">
        <h1 aria-label={boardTitle}>
          <span>Compute</span>
          <span>Current</span>
        </h1>
        <p>
          Autonomous editorial desk tracking the constraints behind the AI buildout: power, cooling, silicon, cloud capacity, data centers, capital, and policy risk.
        </p>
      </div>

      <nav class="nav-strip" aria-label="Coverage navigation">
        {navLinks.map(([label, href]) => <a href={href}>{label}</a>)}
      </nav>
    </header>

    <section class="cycle-brief" aria-label="Desk statistics">
      <div class="brief-kicker">Desk Cycle</div>
      <div class="brief-track">
        {stats.map((stat) => (
          <span><strong>{stat.value}</strong> {stat.label}</span>
        ))}
      </div>
    </section>

    <EditorialCycleStatus model={model} />

    <FeaturedCycleAnalysis items={model.featuredAnalyses} statusLabel={model.freshness.label} />

    {model.activeWatchlist.length ? <ActiveWatchlist items={model.activeWatchlist} /> : null}

    {model.recentAnalysis.length ? <RecentAnalysisArchive items={model.recentAnalysis} /> : null}

    <section class="search-shell">
      <div class="search-copy">
        <p class="eyebrow">Public Archive</p>
        <h2>Find published analysis</h2>
      </div>
      <p class="archive-note">
        The public archive contains published analyses and clean watchlist items. Internal raw source volume is tracked separately in admin quality views.
      </p>
      <a class="detail-link archive-link" href="/archive/">Browse archive</a>
    </section>

    <footer class="transparency-footer" aria-label="Editorial transparency">
      <div>
        <p class="eyebrow">Transparency</p>
        <p>
          AI-assisted infrastructure intelligence with source attribution, extraction QA, signal clustering, claim verification, and publish gates for low-quality generated pages.
        </p>
      </div>
      <nav class="policy-link-row" aria-label="Transparency pages">
        <a href="/about/">About</a>
        <a href="/editorial-policy/">Editorial Policy</a>
        <a href="/methodology/">Methodology</a>
        <a href="/ai-disclosure/">AI-assisted Disclosure</a>
        <a href="/rss.xml">RSS</a>
        <a href="/sitemap.xml">Sitemap</a>
      </nav>
    </footer>
  </main>
</Layout>
