---
import '../styles/global.css';
import newsData from '../data/latest-news.json';

const formatTimeAgo = (iso) => {
  const ms = Date.now() - new Date(iso).getTime();
  const mins = Math.max(1, Math.floor(ms / 60000));
  if (mins < 60) return `${mins}m ago`;
  const hours = Math.floor(mins / 60);
  if (hours < 24) return `${hours}h ago`;
  const days = Math.floor(hours / 24);
  return `${days}d ago`;
};

const cards = (newsData || []).map((item, idx) => ({
  ...item,
  summary: item.summary || item.snippet || '',
  insight: item.insight || 'Expert insight: Capacity, power, and silicon lead times should be planned together for durable AI infrastructure outcomes.',
  image: item.generatedImage || item.image || '/generated/default.svg',
  timeAgo: formatTimeAgo(item.publishedAt),
  isHero: idx === 0,
}));

const hero = cards[0];
const rest = cards.slice(1);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content="Curated AI, data center, and semiconductor intelligence dashboard." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>AI / Data Center Signal Board</title>
  </head>
  <body>
    <div class="page-shell">
      <header class="topbar">
        <div>
          <p class="eyebrow">AI / Data Center Signal Board</p>
          <h1>Curated infrastructure intelligence every 8 hours</h1>
        </div>
        <p class="updated">Updated {new Date().toLocaleString('en-US', { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' })}</p>
      </header>

      {hero && (
        <article class="hero-card">
          <img src={hero.image} alt={hero.title} loading="lazy" />
          <div class="hero-content">
            <div class="meta-row">
              <span class="source-pill">{hero.source}</span>
              <time>{hero.timeAgo}</time>
            </div>
            <h2><a href={hero.url} target="_blank" rel="noopener noreferrer">{hero.title}</a></h2>
            <p class="summary">{hero.summary}</p>
            <p class="insight">{hero.insight}</p>
          </div>
        </article>
      )}

      <section class="masonry-board" aria-label="Latest curated news">
        {rest.map((item) => (
          <article class="news-card">
            <img src={item.image} alt={item.title} loading="lazy" />
            <div class="card-content">
              <div class="meta-row">
                <span class="source-pill">{item.source}</span>
                <time>{item.timeAgo}</time>
              </div>
              <h3><a href={item.url} target="_blank" rel="noopener noreferrer">{item.title}</a></h3>
              <p class="summary">{item.summary}</p>
              <p class="insight">{item.insight}</p>
            </div>
          </article>
        ))}
      </section>
    </div>
  </body>
</html>
