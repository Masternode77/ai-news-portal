---
import Layout from '../layouts/Layout.astro';
import CategoryNav from '../components/CategoryNav.astro';
import FeaturedArticle from '../components/FeaturedArticle.astro';
import LatestAnalysisFeed from '../components/LatestAnalysisFeed.astro';
import latestNews from '../data/latest-news.json';
import archivedNews from '../data/archived-news.json';
import { SITE } from '../config/site';
import { buildHomepageFeed } from '../../scripts/lib/homepage-feed-builder.mjs';

const boardTitle = SITE.name;
const homepageArticles = process.env.HOMEPAGE_FIXTURE === 'empty' ? [] : [...latestNews, ...archivedNews];
const feed = buildHomepageFeed(homepageArticles, { limit: 50, minimumVisible: 30 });
const latestFeed = { ...feed, items: feed.featured ? feed.items.slice(1) : feed.items };

const navLinks = [
  ['Power & Grid', '/category/power-grid/'],
  ['Data Centers', '/category/data-centers/'],
  ['Cloud Capacity', '/category/cloud-capacity/'],
  ['Semiconductors', '/category/semiconductors/'],
  ['Cooling', '/category/cooling/'],
  ['Capital Markets', '/category/capital-markets/'],
  ['Policy & Siting', '/category/regulation/'],
  ['Archive', '/archive/'],
];
---
<Layout title={boardTitle} description="AI infrastructure intelligence for power, data centers, chips, cloud capacity, cooling, and capital." canonicalPath="/">
  <main class="page-shell autonomous-home publication-home">
    <header class="publication-header">
      <div class="edition-line">
        <span>AI Infrastructure Intelligence</span>
        <a href="/rss.xml">RSS</a>
      </div>

      <div class="masthead-row">
        <h1 aria-label={boardTitle}>
          <span>Compute</span>
          <span>Current</span>
        </h1>
        <div class="hero-copy">
          <p>
            AI infrastructure intelligence for power, data centers, chips, cloud capacity, cooling, and capital.
          </p>
          <a class="newsletter-cta" href="/archive/">Browse recent analysis</a>
        </div>
      </div>

      <CategoryNav links={navLinks} />
    </header>

    <FeaturedArticle signal={feed.featured?.publicSignal} />

    <LatestAnalysisFeed
      feed={latestFeed}
      title="Latest Analysis"
      dek="Analysis, briefs, and source-linked signals from the AI infrastructure buildout."
    />

    <section class="search-shell publication-search">
      <div class="search-copy">
        <p class="eyebrow">Archive</p>
        <h2>Search the archive</h2>
      </div>
      <p class="archive-note">
        Browse recent AI infrastructure coverage by source, date, and category.
      </p>
      <a class="detail-link archive-link" href="/archive/">Explore all posts</a>
    </section>

    <footer class="transparency-footer" aria-label="Editorial links">
      <nav class="policy-link-row" aria-label="Publication pages">
        <a href="/about/">About</a>
        <a href="/editorial-policy/">Editorial Policy</a>
        <a href="/methodology/">Methodology</a>
        <a href="/ai-disclosure/">AI-assisted Disclosure</a>
        <a href="/rss.xml">RSS</a>
        <a href="/sitemap.xml">Sitemap</a>
      </nav>
    </footer>
  </main>
</Layout>
