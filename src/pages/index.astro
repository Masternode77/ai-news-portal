---
import Layout from '../layouts/Layout.astro';
import IntelligenceBoard from '../components/IntelligenceBoard.astro';
import latestNews from '../data/latest-news.json';
import archivedNews from '../data/archived-news.json';
import sourceHealth from '../data/source-health.json';
import { SITE } from '../config/site';
import { buildHomepageLaunchModel } from '../../scripts/lib/homepage-launch-model.mjs';

const model = buildHomepageLaunchModel({
  latest: latestNews,
  archived: archivedNews,
  sourceHealth,
});

const navLinks = [
  ['Power & Grid', '/category/power-grid/'],
  ['Data Centers', '/category/data-centers/'],
  ['Cloud Capacity', '/category/cloud-capacity/'],
  ['Semiconductors', '/category/semiconductors/'],
  ['Cooling', '/category/cooling/'],
  ['Capital Markets', '/category/capital-markets/'],
  ['Policy & Siting', '/category/regulation/'],
  ['Archive', '/archive/'],
];
---
<Layout title={SITE.name} description={SITE.description} canonicalPath="/">
  <main class="page-shell launch-home">
    <header class="publication-header launch-header">
      <div class="edition-line">
        <span>AI Infrastructure Intelligence</span>
        <time>
          {new Date().toLocaleString('en-US', {
            month: 'short',
            day: 'numeric',
            hour: 'numeric',
            minute: '2-digit',
          })}
        </time>
      </div>
      <nav class="nav-strip" aria-label="Coverage navigation">
        {navLinks.map(([label, href]) => <a href={href}>{label}</a>)}
      </nav>
    </header>

    <IntelligenceBoard model={model} />

    <section class="search-shell">
      <div class="search-copy">
        <p class="eyebrow">Public Archive</p>
        <h2>Find published analysis</h2>
      </div>
      <p class="archive-note">
        The archive contains public Compute Current analysis and clean watchlist records. Quarantined source records stay out of public discovery.
      </p>
      <a class="detail-link archive-link" href="/archive/">Browse archive</a>
    </section>

    <footer class="transparency-footer" aria-label="Editorial transparency">
      <div>
        <p class="eyebrow">Transparency</p>
        <p>
          Compute Current uses AI-assisted collection, classification, drafting, and quality gates. Public pages are source-derived analysis with visible attribution and conservative evidence boundaries.
        </p>
      </div>
      <nav class="policy-link-row" aria-label="Transparency pages">
        <a href="/about/">About</a>
        <a href="/editorial-policy/">Editorial Policy</a>
        <a href="/methodology/">Methodology</a>
        <a href="/ai-disclosure/">AI-assisted Disclosure</a>
        <a href="/subscribe/">Subscribe</a>
        <a href="/rss.xml">RSS</a>
        <a href="/sitemap.xml">Sitemap</a>
      </nav>
    </footer>
  </main>
</Layout>
