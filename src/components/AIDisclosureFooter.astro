---
const { canonicalUrl = '' } = Astro.props;
---
<section class="detail-section ai-disclosure-footer">
  <p>
    Compute Current uses AI-assisted research and editing with human editorial standards, source attribution, and publication checks.
    <a href="/ai-disclosure/">Read the disclosure</a>.
  </p>
  {canonicalUrl ? <p class="canonical-note">Canonical page: <a href={canonicalUrl}>{canonicalUrl}</a></p> : null}
  <nav class="policy-link-row disclosure-policy-links" aria-label="Publication policies">
    <a href="/editorial-policy/">Editorial policy</a>
    <a href="/privacy/">Privacy</a>
    <a href="/terms/">Terms</a>
    <a href="/contact/">Contact</a>
  </nav>
</section>
