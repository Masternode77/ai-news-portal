---
import { safePublicHttpUrl } from '../lib/public-url.js';

const { source } = Astro.props;
const sourceUrl = safePublicHttpUrl(source?.url);
---
<section class="source-attribution" aria-label="Source attribution">
  <span>Source</span>
  <p>
    Based on reporting from <strong>{source.name}</strong>{source.domain ? <> ({source.domain})</> : null}.
    {sourceUrl ? (
      <a href={sourceUrl} target="_blank" rel="noopener noreferrer">Read the source</a>
    ) : null}
  </p>
</section>
