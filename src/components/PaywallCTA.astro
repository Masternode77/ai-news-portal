---
const { policy } = Astro.props;
---
<section class="paywall-cta" data-premium-preview>
  <p class="eyebrow">Premium Intelligence</p>
  <h2>{policy.accessLevel === 'enterprise' ? 'Enterprise access required' : 'Continue with Pro'}</h2>
  <p>
    This memo is prepared for paid Compute Current readers. The public preview remains available, while full access is reserved for subscribers and enterprise teams.
  </p>
  <a href={policy.ctaHref} data-analytics-event="paywall_cta_click" data-analytics-label={policy.accessLevel}>
    {policy.ctaLabel}
  </a>
</section>
