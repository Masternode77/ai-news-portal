---
interface Props {
  model?: {
    freshness?: {
      state?: string;
      label?: string;
      latest_source_scanned_at?: string | null;
      latest_published_analysis_at?: string | null;
    };
    latestCycle?: {
      published_analyses?: unknown[];
    } | null;
    stats?: {
      publishedThisCycle?: number;
    };
  };
}

type Assert<T extends true> = T;
type StatusModel = NonNullable<Props['model']>;
type FreshnessModel = NonNullable<StatusModel['freshness']>;
export type NullableStatusContract = [
  Assert<null extends StatusModel['latestCycle'] ? true : false>,
  Assert<null extends FreshnessModel['latest_source_scanned_at'] ? true : false>,
  Assert<null extends FreshnessModel['latest_published_analysis_at'] ? true : false>,
];

const { model } = Astro.props as Props;
const freshness = model?.freshness || {};
const cycle = model?.latestCycle || {};
const fmt = (value?: string | null) => value ? new Date(value).toLocaleString('en-US', { month: 'short', day: 'numeric', hour: 'numeric', minute: '2-digit' }) : 'n/a';
---
<section class="cycle-status" aria-label="Latest update">
  <div>
    <p class="eyebrow">Latest Update</p>
    <h2>{freshness.state === 'fresh' ? 'Latest coverage is current' : freshness.label || 'More analysis is coming soon'}</h2>
  </div>
  <div class="cycle-grid">
    <div><span>Recent source time</span><strong>{fmt(freshness.latest_source_scanned_at)}</strong></div>
    <div><span>Recent analysis time</span><strong>{fmt(freshness.latest_published_analysis_at)}</strong></div>
    <div><span>Recent stories</span><strong>{model?.stats?.publishedThisCycle ?? cycle?.published_analyses?.length ?? 0}</strong></div>
  </div>
</section>
