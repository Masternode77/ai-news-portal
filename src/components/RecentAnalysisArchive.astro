---
import PublicSignalCard from './PublicSignalCard.astro';
import type { ComponentProps } from 'astro/types';

interface Props {
  items?: Array<{ publicSignal: ComponentProps<typeof PublicSignalCard>['signal'] }>;
}

const { items = [] } = Astro.props as Props;
---
<section class="intelligence-section recent-analysis">
  <div class="lane-heading">
    <div>
      <p class="eyebrow">Recent Analysis</p>
      <h2>Published desk work</h2>
    </div>
    <p>Local Compute Current articles remain available with source attribution and full detail pages.</p>
  </div>
  <div class="lane-grid">
    {items.map((item) => <PublicSignalCard signal={item.publicSignal} />)}
  </div>
</section>
