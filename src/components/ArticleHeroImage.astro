---
const {
  image = '/generated/fallbacks/ai-infrastructure.svg',
  imageAlt = 'Compute Current editorial visual',
  provenanceLabel = '',
  provenanceKind = '',
  caption = '',
} = Astro.props;
const safeImage = image || '/generated/fallbacks/ai-infrastructure.svg';
---
<figure class="article-hero-image publication-hero-image">
  <img src={safeImage} alt={imageAlt} loading="eager" decoding="async" fetchpriority="high" />
  {provenanceLabel ? (
    <span
      class="article-image-provenance"
      data-image-provenance
      data-provenance-kind={provenanceKind || undefined}
    >
      {provenanceLabel}
    </span>
  ) : null}
  {caption ? <figcaption>{caption}</figcaption> : null}
</figure>
