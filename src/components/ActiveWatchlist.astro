---
import PublicSignalCard from './PublicSignalCard.astro';
import type { ComponentProps } from 'astro/types';

interface Props {
  items?: Array<{ publicSignal: ComponentProps<typeof PublicSignalCard>['signal'] }>;
}

const { items = [] } = Astro.props as Props;
---
<section class="intelligence-section active-watchlist">
  <div class="lane-heading">
    <div>
      <p class="eyebrow">Briefs</p>
      <h2>Recent infrastructure signals</h2>
    </div>
    <p>Short source-linked items from the AI infrastructure buildout.</p>
  </div>
  <div class="lane-grid">
    {items.map((item) => <PublicSignalCard signal={item.publicSignal} />)}
  </div>
</section>
