---
import PublicSignalCard from './PublicSignalCard.astro';
const { items = [] } = Astro.props;
---
<section class="intelligence-section active-watchlist">
  <div class="lane-heading">
    <div>
      <p class="eyebrow">Active Watchlist</p>
      <h2>Signals being monitored</h2>
    </div>
    <p>Clean signals that remain below the bar for full analysis until stronger evidence appears.</p>
  </div>
  <div class="lane-grid">
    {items.map((item) => <PublicSignalCard signal={item.publicSignal} />)}
  </div>
</section>
