---
const { item } = Astro.props;
const signal = item.publicSignal;
---
<article class="launch-card source-watch-card" data-public-card data-card-kind="source-watch" data-lane="source-watch">
  <div class="story-meta">
    <span class="public-signal-label">Source Watch</span>
    <span>{signal.editorial_lens || 'Adjacent Watchlist'}</span>
    <span>{signal.region}</span>
  </div>
  <h3>{signal.title}</h3>
  <p class="signal-deck">{signal.deck}</p>
  <p class="source-watch-note">This is tracked as a source signal, not a full Compute Current analysis.</p>
  <div class="card-footer">
    {signal.read_source ? <a class="source-cta" href={signal.read_source} target="_blank" rel="noreferrer">Read source</a> : null}
  </div>
</article>
