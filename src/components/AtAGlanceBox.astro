---
const { items = [] } = Astro.props;
const visibleItems = Array.isArray(items) ? items.filter(Boolean).slice(0, 3) : [];
---
{visibleItems.length ? (
  <section class="executive-summary at-a-glance-box" aria-label="At a glance">
    <span>At a glance</span>
    <ol>
      {visibleItems.map((item: string) => <li>{item}</li>)}
    </ol>
  </section>
) : null}
