---
const { category, date, source, title, deck, image, imageAlt } = Astro.props;
const formattedDate = date
  ? new Date(date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })
  : '';
---
<header class="article-header">
  <a class="back-link" href="/">Latest analysis</a>
  <div class="meta-strip article-meta-strip">
    {category ? <span class="category-badge">{category}</span> : null}
    {formattedDate ? <time datetime={date}>{formattedDate}</time> : null}
    {source?.name ? <span>{source.name}</span> : null}
  </div>
  <h1>{title}</h1>
  {deck ? <p class="detail-summary">{deck}</p> : null}
  <p class="byline">By Compute Current Editorial Desk</p>
  {image ? (
    <figure class="article-hero-image">
      <img src={image} alt={imageAlt || `${title} editorial visual`} loading="eager" decoding="async" />
    </figure>
  ) : null}
</header>
