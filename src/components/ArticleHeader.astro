---
const { category, date, source, title, deck, formatLabel = 'Analyst Note' } = Astro.props;
const formattedDate = date
  ? new Date(date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })
  : '';
---
<header class="article-header">
  <nav class="article-breadcrumb" aria-label="Breadcrumb">
    <a href="/">Compute Current</a>
    <span aria-hidden="true">/</span>
    <a href="/">Latest analysis</a>
  </nav>
  <div class="meta-strip article-meta-strip">
    <span class="article-format-label">{formatLabel}</span>
    {category ? <span class="category-badge">{category}</span> : null}
    {formattedDate ? <time datetime={date}>{formattedDate}</time> : null}
    {source?.name ? <span>{source.name}</span> : null}
  </div>
  <h1>{title}</h1>
  {deck ? <p class="detail-summary">{deck}</p> : null}
  <p class="byline">By Compute Current</p>
</header>
