---
const { compact = false } = Astro.props;
const interests = [
  'Power & Grid',
  'Data Centers',
  'Cooling',
  'Silicon & Systems',
  'Cloud Capacity',
  'Capital & Deals',
  'Policy & Siting',
  'Enterprise Infrastructure',
];
---
<section class:list={['newsletter-capture', compact && 'newsletter-capture-compact']}>
  <div>
    <p class="eyebrow">Daily Brief</p>
    <h2>Get the Daily AI Infrastructure Brief</h2>
    <p>Power, capacity, silicon, cooling, cloud, capital, and policy signals behind the AI buildout.</p>
  </div>
  <form class="newsletter-form" action="/subscribe/" method="get" data-analytics-event="newsletter_signup_view">
    <label>
      <span>Email</span>
      <input type="email" name="email" placeholder="you@example.com" required />
    </label>
    <label>
      <span>Role</span>
      <select name="role">
        <option>Operator</option>
        <option>Investor</option>
        <option>Cloud buyer</option>
        <option>Developer</option>
        <option>Advisor</option>
      </select>
    </label>
    <label>
      <span>Focus</span>
      <select name="interest">
        {interests.map((interest) => <option>{interest}</option>)}
      </select>
    </label>
    <button type="submit">Subscribe</button>
  </form>
</section>
