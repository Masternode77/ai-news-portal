---
import SourceAttribution from './SourceAttribution.astro';

const { title, deck, byline, sourceAttribution, taxonomy, presentation, publishedAt } = Astro.props;
---
<header class="public-article-header">
  <nav class="breadcrumb" aria-label="Breadcrumb">
    <a href="/">Home</a>
    <span>/</span>
    <span>{taxonomy.primary}</span>
  </nav>

  <div class="meta-strip">
    <span class="category-badge">{taxonomy.primary}</span>
    <span class="source-pill">{presentation.signal_label}</span>
    <span class="region-pill">{presentation.region}</span>
    <time>{new Date(publishedAt).toLocaleString('en-US')}</time>
  </div>

  <h1>{title}</h1>
  <p class="detail-summary">{deck}</p>
  <p class="byline">{byline || 'By Compute Current Editorial Desk'}</p>
  <SourceAttribution source={sourceAttribution} />
</header>
