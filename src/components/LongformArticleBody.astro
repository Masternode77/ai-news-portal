---
const { blocks = [] } = Astro.props;
const isHeading = (paragraph: string) =>
  paragraph.length <= 86 &&
  !/[.!?]$/.test(paragraph) &&
  /^[A-Z0-9][A-Za-z0-9 &:/+-]+$/.test(paragraph);
let paragraphIndex = 0;
---
<section class="detail-section detail-article-copy longform-article-body" aria-label="Article analysis">
  {blocks.map((paragraph: string) => {
    if (isHeading(paragraph)) {
      return <h2>{paragraph}</h2>;
    }
    paragraphIndex += 1;
    return <p class={paragraphIndex === 1 ? 'article-lede-paragraph' : undefined}>{paragraph}</p>;
  })}
</section>
