---
import ArticleCardImage from './ArticleCardImage.astro';

const { signal, compact = false, priority = false } = Astro.props;
const impact = Array.isArray(signal.reader_impact) ? signal.reader_impact.slice(0, 4) : [];
const image = signal.image || signal.image_url || '/generated/fallbacks/ai-infrastructure.svg';
const imageAlt = signal.image_alt || `${signal.title || 'Compute Current signal'} visual`;
const provenanceLabel = signal.image_provenance_label || 'Editorial visual';
const provenanceKind = signal.image_provenance_kind || 'image2';
---
<article
  class:list={['intel-card', compact && 'intel-card-compact']}
  data-public-card
  data-article-id={signal.id}
  data-lane={signal.lane_key}
  data-deck={signal.deck}
>
  {image ? (
    <ArticleCardImage
      image={image}
      imageAlt={imageAlt}
      href={signal.view_detail || ''}
      linkClassName="signal-media"
      priority={priority}
      decorative={!signal.view_detail}
      ariaLabel={signal.view_detail ? `Open ${signal.title}` : ''}
      provenanceLabel={provenanceLabel}
      provenanceKind={provenanceKind}
    />
  ) : null}
  <div class="story-meta">
    <span class="public-signal-label">{signal.signal_label}</span>
    <span>{signal.editorial_lens}</span>
    <span>{signal.region}</span>
  </div>
  <h3>
    {signal.view_detail ? <a href={signal.view_detail}>{signal.title}</a> : signal.title}
  </h3>
  <p class="signal-deck">{signal.deck}</p>
  <p class="signal-why">{signal.why_it_matters}</p>
  {impact.length ? (
    <div class="reader-impact" aria-label="Reader impact">
      {impact.map((label: string) => <span>{label}</span>)}
    </div>
  ) : null}
  <div class="card-footer">
    {signal.view_detail ? <a class="detail-link" href={signal.view_detail}>View detail</a> : null}
    {signal.read_source ? <a class="source-cta" href={signal.read_source} target="_blank" rel="noreferrer">Read source</a> : null}
  </div>
</article>
