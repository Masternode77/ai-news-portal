---
interface Props {
  metrics?: string[];
  changeView?: string[];
}

const { metrics = [], changeView = [] } = Astro.props as Props;
---
<section class="detail-section what-to-watch">
  <h2>What to watch</h2>
  <ul>
    {metrics.slice(0, 4).map((metric) => <li>{metric}</li>)}
  </ul>
  {changeView.length ? (
    <>
      <h2>What would change our view</h2>
      <ul>
        {changeView.slice(0, 4).map((item) => <li>{item}</li>)}
      </ul>
    </>
  ) : null}
</section>
