---
import { safePublicHref } from '../lib/public-url.js';

const {
  image = '/generated/fallbacks/ai-infrastructure.svg',
  imageAlt = 'Compute Current editorial visual',
  href = '',
  className = 'article-card-image',
  linkClassName = 'article-card-image-link',
  priority = false,
  decorative = false,
  ariaLabel = '',
  provenanceLabel = '',
  provenanceKind = '',
  width = 1200,
  height = 900,
} = Astro.props;

const safeImage = image || '/generated/fallbacks/ai-infrastructure.svg';
const safeHref = safePublicHref(href);
const isExternal = safeHref.startsWith('http://') || safeHref.startsWith('https://');
const loading = priority ? 'eager' : 'lazy';
const alt = decorative ? '' : imageAlt;
const hasProvenance = Boolean(provenanceLabel || provenanceKind);
---
{safeHref ? (
  <a
    class={linkClassName}
    href={safeHref}
    target={isExternal ? '_blank' : undefined}
    rel={isExternal ? 'noopener noreferrer' : undefined}
    aria-label={ariaLabel || undefined}
    data-image-provenance={hasProvenance ? '' : undefined}
    data-provenance-kind={provenanceKind || undefined}
  >
    <img class={className} src={safeImage} alt={alt} width={width} height={height} loading={loading} decoding="async" fetchpriority={priority ? 'high' : 'auto'} />
  </a>
) : (
  <div
    class={linkClassName}
    aria-hidden={decorative ? 'true' : undefined}
    data-image-provenance={hasProvenance ? '' : undefined}
    data-provenance-kind={provenanceKind || undefined}
  >
    <img class={className} src={safeImage} alt={alt} width={width} height={height} loading={loading} decoding="async" fetchpriority={priority ? 'high' : 'auto'} />
  </div>
)}
