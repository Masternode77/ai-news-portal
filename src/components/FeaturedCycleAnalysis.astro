---
import PublicSignalCard from './PublicSignalCard.astro';
import type { ComponentProps } from 'astro/types';

type FeedItem = { publicSignal: ComponentProps<typeof PublicSignalCard>['signal'] };

interface Props {
  items?: FeedItem[];
  fallbackItems?: FeedItem[];
  statusLabel?: string;
}

const { items = [], fallbackItems = [], statusLabel = '' } = Astro.props as Props;
const displayItems = items.length ? items : fallbackItems;
const showingFallback = !items.length && fallbackItems.length;
---
<section class="featured-cycle" aria-label="Featured analysis from latest editorial cycle">
  <div class="lane-heading">
    <div>
      <p class="eyebrow">{showingFallback ? 'Latest Analysis' : 'Featured Analysis'}</p>
      <h2>{showingFallback ? 'Latest articles' : 'Editor-selected analysis'}</h2>
    </div>
    <p>
      {showingFallback
        ? 'Recent article pages and briefs from the public archive.'
        : 'Recent AI infrastructure analysis with source attribution.'}
    </p>
  </div>
  {displayItems.length ? (
    <div class="lane-grid featured-grid">
      {displayItems.map((item, index) => <PublicSignalCard signal={item.publicSignal} priority={index === 0} />)}
    </div>
  ) : (
    <div class="cycle-empty">
      <h3>No new stories yet.</h3>
      <p>{statusLabel || 'More analysis is coming soon.'}</p>
    </div>
  )}
</section>
