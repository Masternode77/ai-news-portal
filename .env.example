# Compute Current environment template
# Leave values blank locally unless the feature is enabled. Never commit real secrets.

# Admin authentication
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=$argon2id$v=19$m=19456,t=2,p=1$replace-with-salt$replace-with-derived-key
ADMIN_SESSION_SECRET=replace-with-64-plus-random-characters
ADMIN_ROLE=admin
ADMIN_USER_ROLES={}

# Durable admin persistence and private media
DATABASE_URL=
ADMIN_DATABASE_POOL_SIZE=1
ADMIN_MEDIA_PROVIDER=vercel-blob
BLOB_READ_WRITE_TOKEN=
ADMIN_SEED_JSON=0

# Legacy GitHub-backed content automation
GITHUB_TOKEN=
GH_TOKEN=
COMPUTE_CURRENT_GITHUB_TOKEN=
GITHUB_REPO=Masternode77/ai-news-portal
GITHUB_BRANCH=main

# Content cycle and pipeline
PIPELINE_OFFLINE=0
PIPELINE_USE_EXISTING_POOL=0
CONTENT_CYCLE_FIXTURE=tests/fixtures/content-cycle-mixed.json
FORCE_GENERATION_FAILURE=0
REFRESH_INTERVAL_HOURS=8
MAX_ITEMS_FETCHED=30
MIN_ITEMS_PER_SOURCE_IN_POOL=1
DAILY_CURATION_TARGET=6
ITEMS_PER_RUN=2
FRESH_CANDIDATE_WINDOW_HOURS=24
LATEST_NEWS_LIMIT=30
PIPELINE_RETRY_DELAY_MS=15000

# Text generation
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-5.3-codex
OPENROUTER_SITE_URL=
OPENROUTER_APP_TITLE=Compute Current
EXPERT_LENS_MODEL=openai/gpt-5.4
EXPERT_LENS_FALLBACK_MODEL=openai/gpt-5.3-codex

# Image generation
IMAGE_PROVIDER=image2
OPENAI_API_KEY=
OPENAI_IMAGE_API_URL=https://api.openai.com/v1/images/generations
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_SIZE=1536x1024
OPENAI_IMAGE_QUALITY=medium
IMAGE2_HERO_SIZE=1536x864
IMAGE2_OUTPUT_FORMAT=webp
IMAGE2_PUBLIC_DIR=public
CHATGPT_IMAGE_OAUTH_ENDPOINT=
CHATGPT_IMAGE_OAUTH_ACCESS_TOKEN=
GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# Archive persistence
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ARCHIVE_TABLE=archived_articles

# Cache and deployment purge
COMPUTE_CURRENT_CACHE_PURGE_URL=
COMPUTE_CURRENT_CACHE_PURGE_TOKEN=
VERCEL_DEPLOY_HOOK_URL=
VERCEL_TOKEN=

# QA and preview controls
PUBLIC_OUTPUT_ARTICLE_LIMIT=50
PUBLIC_OUTPUT_MIN_LONGFORM_CHARS=4500
PUBLIC_SURFACE_ARTICLE_LIMIT=30
PUBLIC_SURFACE_BASE_URL=
PUBLIC_CONTENT_QUALITY_ARTICLE_LIMIT=50
PUBLIC_CONTENT_QUALITY_BASE_URL=
PREVIEW_HOST=127.0.0.1
PREVIEW_PORT=4173
PREVIEW_BASE_URL=
PERCY_TOKEN=
GITHUB_ACTIONS=

# Notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional source/network controls
SOURCE_HEALTH_SKIP_NETWORK=1
SOURCE_HEALTH_NETWORK=0
SOURCE_HEALTH_TIMEOUT_MS=4000
EMERGENCY_CLEANUP_ARCHIVE_LIMIT=100000
PUBLIC_CONTENT_REGEN_LIMIT=100
LONGFORM_TARGET=15
BRIEF_TARGET=35
NARRATIVE_DNA_REGENERATE_COUNT=100
EVAL_ARTICLE_LIMIT=10
ARTICLE_PAGE_QUALITY_THRESHOLD=0.8
WORKSPACE_ROOT=
CRON_SNAPSHOT_PATH=
